---
const {
  title = "Collaborations — Guss Damn Good",
  description = "100+ brand partnerships. Collab flavors, OEM/ODM, events and campaigns.",
  partnerName = "",
  partnerLogo = "",
  heroImage = "",
  projectType = ""
} = Astro.props;

const projectTypeLabels = {
  collab_flavor: "Collab Flavor",
  oem_odm: "OEM / ODM",
  catering: "Event Catering",
  campaign: "Campaign",
  wedding: "Wedding"
};

const typeLabel = projectTypeLabels[projectType] || projectType;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={heroImage} />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="b2b-body">

    <!-- B2B CORPORATE NAV -->
    <nav class="b2b-topnav">
      <div class="b2b-topnav__inner">
        <a href="/" class="b2b-topnav__logo">
          <span class="b2b-topnav__logo-name">Guss Damn Good</span>
          <span class="b2b-topnav__logo-sub">Partnerships & Collaborations</span>
        </a>
        <ul class="b2b-topnav__links">
          <li><a href="/collabs">Case Studies</a></li>
          <li><a href="/story">About</a></li>
          <li><a href="/flavors">Flavors</a></li>
          <li>
            <a href="mailto:collab@gussdamngood.com" class="b2b-topnav__cta">
              Work With Us
            </a>
          </li>
        </ul>

        <!-- Mobile hamburger -->
        <button class="b2b-topnav__mobile-toggle" id="b2b-toggle" aria-label="Menu">
          <span /><span />
        </button>
      </div>

      <!-- Mobile dropdown -->
      <div class="b2b-topnav__mobile-menu" id="b2b-mobile-menu">
        <a href="/collabs">Case Studies</a>
        <a href="/story">About</a>
        <a href="/flavors">Flavors</a>
        <a href="mailto:collab@gussdamngood.com">Work With Us</a>
      </div>
    </nav>

    <!-- HERO IMAGE BAND -->
    {heroImage && (
      <div class="b2b-hero">
        <img src={heroImage} alt={partnerName} class="b2b-hero__img" />
        <div class="b2b-hero__overlay" />
        <div class="b2b-hero__meta">
          {partnerLogo && (
            <img src={partnerLogo} alt={`${partnerName} logo`} class="b2b-hero__partner-logo" />
          )}
          <div class="b2b-hero__tags">
            {typeLabel && <span class="b2b-tag">{typeLabel}</span>}
            {partnerName && <span class="b2b-tag b2b-tag--accent">{partnerName}</span>}
          </div>
        </div>
      </div>
    )}

    <!-- MAIN CONTENT -->
    <main class="b2b-main">
      <div class="b2b-main__inner">

        <!-- Left: content slot -->
        <article class="b2b-article">
          <slot />
        </article>

        <!-- Right: sidebar -->
        <aside class="b2b-sidebar">
          <div class="b2b-sidebar__card">
            <p class="b2b-sidebar__label">Partnership Type</p>
            <p class="b2b-sidebar__value">{typeLabel || "—"}</p>
          </div>
          <div class="b2b-sidebar__card">
            <p class="b2b-sidebar__label">Brand Partner</p>
            <p class="b2b-sidebar__value">{partnerName || "—"}</p>
          </div>
          <div class="b2b-sidebar__divider" />
          <div class="b2b-sidebar__cta-block">
            <p class="b2b-sidebar__cta-title">Start a collaboration</p>
            <p class="b2b-sidebar__cta-body">
              We craft collab flavors, OEM/ODM products, event catering,
              and campaign drops for brands across every world.
            </p>
            <a href="mailto:collab@gussdamngood.com" class="b2b-sidebar__cta-btn">
              Get in touch →
            </a>
          </div>
          <div class="b2b-sidebar__divider" />
          <div class="b2b-sidebar__stats">
            <div class="b2b-sidebar__stat">
              <span class="b2b-sidebar__stat-num">100+</span>
              <span class="b2b-sidebar__stat-label">Brand Partners</span>
            </div>
            <div class="b2b-sidebar__stat">
              <span class="b2b-sidebar__stat-num">10+</span>
              <span class="b2b-sidebar__stat-label">Years</span>
            </div>
          </div>
        </aside>

      </div>
    </main>

    <!-- B2B FOOTER -->
    <footer class="b2b-footer">
      <div class="b2b-footer__inner">
        <div>
          <p class="b2b-footer__brand">Guss Damn Good</p>
          <p class="b2b-footer__sub">Feeling-Crafted Ice Cream · Bangkok · Since 2014</p>
        </div>
        <div class="b2b-footer__links">
          <a href="/collabs">All Case Studies</a>
          <a href="/story">Our Story</a>
          <a href="mailto:collab@gussdamngood.com">collab@gussdamngood.com</a>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('b2b-toggle');
      const menu = document.getElementById('b2b-mobile-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          menu.classList.toggle('open');
        });
      }
    </script>

  </body>
</html>

<style>
  .b2b-body {
    background: #0F0F0F;
    color: #F5F0E8;
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* Top nav */
  .b2b-topnav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.97);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .b2b-topnav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .b2b-topnav__logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .b2b-topnav__logo-name {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    color: #F5F0E8;
    font-weight: 400;
  }

  .b2b-topnav__logo-sub {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #333;
  }

  .b2b-topnav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .b2b-topnav__links a {
    text-decoration: none;
    color: #555;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .b2b-topnav__links a:hover {
    color: #F5F0E8;
  }

  .b2b-topnav__cta {
    padding: 0.5rem 1.25rem !important;
    border: 1px solid rgba(245,230,66,0.3) !important;
    border-radius: 999px !important;
    color: #F5E642 !important;
    font-size: 0.78rem !important;
    transition: all 0.2s !important;
  }

  .b2b-topnav__cta:hover {
    background: #F5E642 !important;
    color: #0F0F0F !important;
  }

  .b2b-topnav__mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .b2b-topnav__mobile-toggle span {
    display: block;
    width: 20px;
    height: 1px;
    background: #F5F0E8;
  }

  .b2b-topnav__mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem 1.5rem;
    gap: 1rem;
    border-top: 1px solid #1a1a1a;
  }

  .b2b-topnav__mobile-menu.open {
    display: flex;
  }

  .b2b-topnav__mobile-menu a {
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .b2b-topnav__mobile-menu a:hover {
    color: #F5F0E8;
  }

  /* Hero */
  .b2b-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
    margin-top: 65px;
  }

  .b2b-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
  }

  .b2b-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15,15,15,1) 0%,
      rgba(15,15,15,0.4) 50%,
      rgba(15,15,15,0.1) 100%
    );
  }

  .b2b-hero__meta {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    right: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .b2b-hero__partner-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .b2b-hero__tags {
    display: flex;
    gap: 0.5rem;
  }

  .b2b-tag {
    padding: 0.3rem 0.9rem;
    border: 1px solid #333;
    border-radius: 999px;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #666;
  }

  .b2b-tag--accent {
    border-color: rgba(245,230,66,0.3);
    color: #F5E642;
  }

  /* Main content area */
  .b2b-main {
    padding: 4rem 2rem;
  }

  .b2b-main__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }

  /* Article typography */
  .b2b-article {
    max-width: 680px;
  }

  .b2b-article :global(h1) {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #F5F0E8;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }

  .b2b-article :global(h2) {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #F5F0E8;
    margin: 3rem 0 1rem;
  }

  .b2b-article :global(p) {
    font-size: 1rem;
    color: #888;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .b2b-article :global(strong) {
    color: #F5F0E8;
    font-weight: 500;
  }

  .b2b-article :global(em) {
    color: #F5E642;
    font-style: italic;
  }

  .b2b-article :global(blockquote) {
    border-left: 2px solid #F5E642;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    color: #F5F0E8;
    font-style: italic;
    line-height: 1.5;
  }

  .b2b-article :global(img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 2rem 0;
    object-fit: cover;
  }

  /* Sidebar */
  .b2b-sidebar {
    position: sticky;
    top: 90px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    overflow: hidden;
  }

  .b2b-sidebar__card {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #1a1a1a;
    background: #131313;
  }

  .b2b-sidebar__label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #333;
    margin-bottom: 0.3rem;
  }

  .b2b-sidebar__value {
    font-size: 0.95rem;
    color: #F5F0E8;
    font-weight: 400;
  }

  .b2b-sidebar__divider {
    height: 1px;
    background: #1a1a1a;
  }

  .b2b-sidebar__cta-block {
    padding: 1.5rem;
    background: #131313;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .b2b-sidebar__cta-title {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    color: #F5F0E8;
  }

  .b2b-sidebar__cta-body {
    font-size: 0.8rem;
    color: #555;
    line-height: 1.6;
  }

  .b2b-sidebar__cta-btn {
    display: inline-block;
    padding: 0.65rem 1.25rem;
    background: #F5E642;
    color: #0F0F0F;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border-radius: 2px;
    transition: opacity 0.2s;
    text-align: center;
  }

  .b2b-sidebar__cta-btn:hover {
    opacity: 0.85;
  }

  .b2b-sidebar__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #131313;
  }

  .b2b-sidebar__stat {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-right: 1px solid #1a1a1a;
  }

  .b2b-sidebar__stat:last-child {
    border-right: none;
  }

  .b2b-sidebar__stat-num {
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #F5E642;
    line-height: 1;
  }

  .b2b-sidebar__stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #333;
  }

  /* Footer */
  .b2b-footer {
    border-top: 1px solid #1a1a1a;
    padding: 2rem;
  }

  .b2b-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .b2b-footer__brand {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    color: #F5F0E8;
    font-weight: 400;
  }

  .b2b-footer__sub {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: #333;
    margin-top: 0.25rem;
    text-transform: uppercase;
  }

  .b2b-footer__links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .b2b-footer__links a {
    color: #333;
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .b2b-footer__links a:hover {
    color: #F5F0E8;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .b2b-topnav__links {
      display: none;
    }

    .b2b-topnav__mobile-toggle {
      display: flex;
    }

    .b2b-main__inner {
      grid-template-columns: 1fr;
    }

    .b2b-sidebar {
      position: static;
    }

    .b2b-article {
      max-width: 100%;
    }
  }
</style>
