---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FlavorCard from '../components/FlavorCard.astro';

const slides = [
  "https://images.unsplash.com/photo-1497034825429-c343d7c6a68f?w=1600&q=80",
  "https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=1600&q=80",
  "https://images.unsplash.com/photo-1505394033641-40b6ad5ef923?w=1600&q=80",
];

const flavors = [
  { flavorName:"Breakfast Fresh Milk",       moodNumber:"Mood #01", productImage:"https://images.unsplash.com/photo-1563805042-7684c019e1cb?w=600&q=80",      category:"classic",  inStock:true,  pinned:true  },
  { flavorName:"Very Addicted Crispy Corn",  moodNumber:"Mood #07", productImage:"https://images.unsplash.com/photo-1488900128323-21503983a07e?w=600&q=80",  category:"classic",  inStock:true,  pinned:true  },
  { flavorName:"S'more Crunch",              moodNumber:"Mood #14", productImage:"https://images.unsplash.com/photo-1534706936160-d5ee67737249?w=600&q=80",   category:"classic",  inStock:true,  pinned:false },
  { flavorName:"Papaya × RIMOWA",            moodNumber:"Collab",   productImage:"https://images.unsplash.com/photo-1560008581-09826d1de69e?w=600&q=80",      category:"collab",   inStock:false, pinned:false },
  { flavorName:"Black Sesame",               moodNumber:"Mood #33", productImage:"https://images.unsplash.com/photo-1497034825429-c343d7c6a68f?w=600&q=80",   category:"classic",  inStock:true,  pinned:false },
  { flavorName:"Mango Sticky Rice",          moodNumber:"Mood #42", productImage:"https://images.unsplash.com/photo-1505394033641-40b6ad5ef923?w=600&q=80",   category:"seasonal", inStock:true,  pinned:false },
];

const collabs = [
  { name:"RIMOWA",    type:"Collab Flavor", img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80",  slug:"rimowa"    },
  { name:"Valentino", type:"Collab Flavor", img:"https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=600&q=80", slug:"valentino" },
  { name:"Hermes",    type:"Collab Flavor", img:"https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=600&q=80",   slug:"rimowa"    },
  { name:"La Mer",    type:"Campaign",      img:"https://images.unsplash.com/photo-1570194065650-d99fb4b8ccb4?w=600&q=80", slug:"rimowa"    },
];
---

<BaseLayout title="Guss Damn Good — Feeling-Crafted Ice Cream">
  <Nav/>
  <Hero slides={slides}/>

  <!-- ABOUT — dimmed, quiet, sophisticated -->
  <section class="about reveal">
    <div class="about__left">
      <p class="eyebrow" style="margin-bottom:1.25rem;">About</p>
      <h2 class="about__h">Ice cream<br/>is a craft.</h2>
      <p class="about__tagline">Story-to-Flavor · Boston Texture · Bangkok Made</p>
    </div>
    <div class="about__right">
      <p class="about__p">Every Guss flavor begins as a story — gathered from the world around us and slowly crafted into a Boston texture: smooth, dense, and never too heavy. Farm-fresh Thai milk, French cream, and a decade of refinement.</p>
      <div class="about__vals">
        <div class="about__val"><span class="about__val-l">F</span><span class="about__val-w">Fun</span></div>
        <div class="about__val"><span class="about__val-l">A</span><span class="about__val-w">Attention to Detail</span></div>
        <div class="about__val"><span class="about__val-l">B</span><span class="about__val-w">Bold</span></div>
      </div>
    </div>
  </section>

  <!-- FLAVORS — 3-column grid, no pinned wide rows -->
  <section class="flavors">
    <div class="flavors__head reveal">
      <h2 class="flavors__title">The Flavors</h2>
      <a href="/flavors" class="flavors__link">View all 200+ →</a>
    </div>
    <div class="fg3">
      {flavors.map((f, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1}`}>
          <FlavorCard {...f}/>
        </div>
      ))}
    </div>
  </section>

  <!-- COLLABS -->
  <section class="hcl">
    <div class="hcl__head reveal">
      <div>
        <p class="eyebrow" style="margin-bottom:0.5rem;">100+ Brand Partners</p>
        <h2 class="hcl__title">Collabs</h2>
      </div>
      <a href="/collabs" class="flavors__link">See all →</a>
    </div>
    <div class="cgrid">
      {collabs.map((c, i) => (
        <a href={`/collabs/${c.slug}`} class={`cg cg-${i} reveal reveal-delay-${i + 1}`}>
          <img src={c.img} alt={c.name} class="cg__img" loading={i < 2 ? 'eager' : 'lazy'}/>
          <div class="cg__dim"/>
          <div class="cg__info">
            <span class="cg__type">{c.type}</span>
            <h3 class="cg__name">{c.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- STATS -->
  <section class="stats reveal">
    <div class="stat"><span class="stat__n">200<em>+</em></span><span class="eyebrow">Flavors</span></div>
    <div class="stat"><span class="stat__n">18</span><span class="eyebrow">Branches</span></div>
    <div class="stat"><span class="stat__n">100<em>+</em></span><span class="eyebrow">Brand Partners</span></div>
    <div class="stat"><span class="stat__n">10<em>+</em></span><span class="eyebrow">Years</span></div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="foot__top">
      <div>
        <p class="foot__brand">Guss Damn Good</p>
        <p class="foot__sub">Feeling-Crafted Ice Cream · Bangkok · Since 2014</p>
      </div>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/story">Story</a>
        <a href="/locations">Find Us</a>
        <a href="/collabs">Collabs</a>
        <a href="/admin">CMS ↗</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good. Bangkok, Thailand.</p>
  </footer>
</BaseLayout>

<style>
  /* ABOUT — deliberately quiet */
  .about { display:grid; grid-template-columns:1fr 1.4fr; border-bottom:1px solid var(--g2); }
  .about__left { padding:clamp(2.5rem,5vw,4.5rem) var(--gutter); border-right:1px solid var(--g2); display:flex; flex-direction:column; justify-content:space-between; gap:1.5rem; }
  .about__h { font-size:clamp(1.5rem,3vw,2.6rem); font-weight:400; color:var(--white); line-height:1.1; letter-spacing:-0.01em; }
  .about__tagline { font-family:var(--f); font-size:0.55rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--g4); font-weight:300; margin-top:0.25rem; }
  .about__right { padding:clamp(2.5rem,5vw,4.5rem) var(--gutter); display:flex; flex-direction:column; justify-content:space-between; gap:2rem; }
  .about__p { font-family:var(--f); font-size:0.85rem; color:var(--g5); line-height:1.9; font-weight:300; max-width:480px; }
  .about__vals { display:flex; gap:2.5rem; padding-top:1.5rem; border-top:1px solid var(--g2); }
  .about__val { display:flex; flex-direction:column; gap:0.2rem; }
  .about__val-l { font-family:var(--f); font-size:1.2rem; font-weight:300; color:var(--g2); line-height:1; }
  .about__val-w { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); font-weight:400; }

  /* FLAVORS — 3 column */
  .flavors { border-bottom:1px solid var(--g2); }
  .flavors__head { display:flex; align-items:baseline; justify-content:space-between; padding:2rem var(--gutter); border-bottom:1px solid var(--g2); }
  .flavors__title { font-size:clamp(1.2rem,2.5vw,1.9rem); font-weight:500; color:var(--white); letter-spacing:-0.01em; }
  .flavors__link { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; font-weight:300; transition:color 0.22s; }
  .flavors__link:hover { color:var(--white); }

  /* 3-col grid — images at square 1:1 = compact */
  .fg3 { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--gap); background:var(--g2); }
  .fg3 .fc__img { aspect-ratio:1/1; }

  /* COLLABS */
  .hcl { border-bottom:1px solid var(--g2); }
  .hcl__head { display:flex; align-items:flex-end; justify-content:space-between; padding:2rem var(--gutter); border-bottom:1px solid var(--g2); }
  .hcl__title { font-size:clamp(1.2rem,2.5vw,1.9rem); font-weight:500; color:var(--white); letter-spacing:-0.01em; margin-top:0.4rem; }
  .cgrid { display:grid; grid-template-columns:2fr 1fr 1fr; grid-template-rows:240px 160px; gap:var(--gap); background:var(--g2); }
  .cg { position:relative; overflow:hidden; display:block; text-decoration:none; background:var(--g1); }
  .cg-0 { grid-row:span 2; }
  .cg-3 { grid-column:2/span 2; }
  .cg__img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.55s ease; filter:grayscale(0.25); }
  .cg:hover .cg__img { transform:scale(1.04); filter:grayscale(0); }
  .cg__dim { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.88) 0%,transparent 55%); }
  .cg__info { position:absolute; bottom:1rem; left:1.15rem; }
  .cg__type { display:block; font-family:var(--f); font-size:0.48rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.38); margin-bottom:0.22rem; font-weight:300; }
  .cg__name { font-family:var(--f); font-weight:500; font-size:clamp(0.9rem,2.2vw,1.5rem); color:var(--white); letter-spacing:-0.01em; }

  /* STATS */
  .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .stat { background:var(--black); padding:2.5rem var(--gutter); display:flex; flex-direction:column; gap:0.5rem; }
  .stat__n { font-family:var(--f); font-weight:400; font-size:clamp(1.8rem,3.5vw,2.8rem); color:var(--white); line-height:1; letter-spacing:-0.02em; }
  .stat__n em { color:var(--g3); font-style:normal; }

  /* FOOTER */
  .foot { padding:2.5rem var(--gutter); display:flex; flex-direction:column; gap:1.5rem; }
  .foot__top { display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.5rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:clamp(1.2rem,2.5vw,2rem); color:var(--white); letter-spacing:0.06em; text-transform:uppercase; }
  .foot__sub { font-family:var(--f); font-size:0.5rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--g4); margin-top:0.3rem; font-weight:300; }
  .foot__nav { display:flex; gap:2rem; flex-wrap:wrap; }
  .foot__nav a { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; font-weight:300; transition:color 0.22s; }
  .foot__nav a:hover { color:var(--white); }
  .foot__copy { font-family:var(--f); font-size:0.48rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:900px){
    .about  { grid-template-columns:1fr; }
    .about__left { border-right:none; border-bottom:1px solid var(--g2); }
    .fg3    { grid-template-columns:repeat(2,1fr); }
    .cgrid  { grid-template-columns:1fr 1fr; grid-template-rows:auto; }
    .cg-0   { grid-row:auto; grid-column:span 2; }
    .cg-3   { grid-column:span 2; }
    .stats  { grid-template-columns:repeat(2,1fr); }
    .foot__top { flex-direction:column; align-items:flex-start; }
  }
  @media(max-width:560px){ .fg3 { grid-template-columns:1fr; } }
</style>
