---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FlavorCard from '../components/FlavorCard.astro';
import { getCollection } from 'astro:content';
import heroData from '../content/settings/hero.json';

const allFlavors = await getCollection('flavors').catch(() => []);
const pinned  = allFlavors.filter(f => f.data.pinned).slice(0,2);
const rest    = allFlavors.filter(f => !f.data.pinned && f.data.status !== 'archive');
const display = [...pinned, ...rest].slice(0, 8);

const collabs = [
  { name:"RIMOWA",    type:"Collab Flavor", img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80",  slug:"rimowa"    },
  { name:"Valentino", type:"Collab Flavor", img:"https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=800&q=80", slug:"valentino" },
  { name:"Hermes",    type:"Collab Flavor", img:"https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=800&q=80",   slug:"rimowa"    },
  { name:"La Mer",    type:"Campaign",      img:"https://images.unsplash.com/photo-1570194065650-d99fb4b8ccb4?w=800&q=80", slug:"rimowa"    },
];
---

<BaseLayout title="Guss Damn Good — Feeling-Crafted Ice Cream">
  <Nav/>
  <Hero
    mediaType={heroData.media_type}
    videoUrl={heroData.video_url}
    photos={heroData.photos}
    activePhoto={heroData.active_photo || 0}
    line1={heroData.headline1}
    line2={heroData.headline2}
    subline={heroData.subline}
    ctaText={heroData.cta_text}
    ctaUrl={heroData.cta_url}
  />

  <!-- ABOUT -->
  <section class="about reveal">
    <div class="about__left">
      <p class="eyebrow" style="margin-bottom:1rem;">About</p>
      <h2 class="about__h">Ice cream<br/>is a craft.</h2>
      <p class="about__tag">Story-to-Flavor · Boston Texture · Bangkok Made</p>
    </div>
    <div class="about__right">
      <p class="about__p">Every Guss flavor begins as a story — gathered from the world around us and slowly crafted into a Boston texture: smooth, dense, and never too heavy. Farm-fresh Thai milk, French cream, and a decade of refinement.</p>
      <div class="about__vals">
        <div class="aval"><span class="aval__l">F</span><span class="aval__w">Fun</span></div>
        <div class="aval"><span class="aval__l">A</span><span class="aval__w">Attention to Detail</span></div>
        <div class="aval"><span class="aval__l">B</span><span class="aval__w">Bold</span></div>
      </div>
    </div>
  </section>

  <!-- FLAVORS — 4-col desktop, 2-col mobile -->
  <section class="fl">
    <div class="fl__head reveal">
      <h2 class="fl__title">The Flavors</h2>
      <a href="/flavors" class="fl__link">View all →</a>
    </div>
    <div class="fg4">
      {display.length > 0
        ? display.map((f,i) => (
            <div class={`reveal reveal-delay-${(i%4)+1}`}>
              <FlavorCard
                flavorName={f.data.flavor_name}
                moodNumber={f.data.mood_number}
                productImage={f.data.product_image}
                productVideo={f.data.product_video}
                category={f.data.category}
                inStock={f.data.in_stock}
                pinned={f.data.pinned}
                description={f.data.description}
              />
            </div>
          ))
        : <p class="fl__empty">No flavors yet — add some in the CMS.</p>
      }
    </div>
  </section>

  <!-- COLLABS -->
  <section class="hcl">
    <div class="hcl__head reveal">
      <div>
        <p class="eyebrow" style="margin-bottom:0.5rem;">100+ Brand Partners</p>
        <h2 class="hcl__title">Collabs</h2>
      </div>
      <a href="/collabs" class="fl__link">See all →</a>
    </div>
    <div class="cgrid">
      {collabs.map((c,i) => (
        <a href={`/collabs/${c.slug}`} class={`cg cg-${i} reveal reveal-delay-${i+1}`}>
          <img src={c.img} alt={c.name} class="cg__img" loading={i<2?'eager':'lazy'}/>
          <div class="cg__dim"/>
          <div class="cg__info">
            <span class="cg__type">{c.type}</span>
            <h3 class="cg__name">{c.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- STATS — compact -->
  <section class="stats reveal">
    <div class="stat"><span class="stat__n">{allFlavors.length>5?`${allFlavors.length}+`:'200+'}</span><span class="eyebrow">Flavors</span></div>
    <div class="stat"><span class="stat__n">18</span><span class="eyebrow">Branches</span></div>
    <div class="stat"><span class="stat__n">100<em>+</em></span><span class="eyebrow">Brand Partners</span></div>
    <div class="stat"><span class="stat__n">10<em>+</em></span><span class="eyebrow">Years</span></div>
  </section>

  <footer class="foot">
    <div class="foot__top">
      <div>
        <p class="foot__brand">Guss Damn Good</p>
        <p class="foot__sub">Feeling-Crafted Ice Cream · Bangkok · Since 2014</p>
      </div>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a><a href="/story">Story</a>
        <a href="/locations">Find Us</a><a href="/collabs">Collabs</a>
        <a href="/admin">CMS ↗</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good. Bangkok, Thailand.</p>
  </footer>
</BaseLayout>

<style>
  /* ABOUT */
  .about { display:grid; grid-template-columns:1fr 1.4fr; border-bottom:1px solid var(--g2); }
  .about__left { padding:clamp(2.5rem,5vw,4.5rem) var(--gutter); border-right:1px solid var(--g2); display:flex; flex-direction:column; gap:1rem; }
  .about__h { font-size:clamp(1.6rem,3.5vw,3rem); font-weight:400; color:#FFFFFF; line-height:1.1; letter-spacing:-0.015em; }
  .about__tag { font-family:var(--f); font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--g4); font-weight:300; }
  .about__right { padding:clamp(2.5rem,5vw,4.5rem) var(--gutter); display:flex; flex-direction:column; justify-content:space-between; gap:2rem; }
  .about__p { font-family:var(--f); font-size:0.92rem; color:#FFFFFF; line-height:1.9; font-weight:300; opacity:0.65; max-width:500px; }
  .about__vals { display:flex; gap:2.5rem; padding-top:1.5rem; border-top:1px solid var(--g2); }
  .aval { display:flex; flex-direction:column; gap:0.2rem; }
  .aval__l { font-family:var(--f); font-size:1.4rem; font-weight:200; color:rgba(255,255,255,0.15); line-height:1; }
  .aval__w { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:#FFFFFF; font-weight:400; opacity:0.7; }

  /* FLAVORS */
  .fl { border-bottom:1px solid var(--g2); }
  .fl__head { display:flex; align-items:baseline; justify-content:space-between; padding:1.75rem var(--gutter); border-bottom:1px solid var(--g2); }
  .fl__title { font-size:clamp(1.1rem,2.2vw,1.7rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.01em; }
  .fl__link { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; font-weight:300; transition:color 0.22s; }
  .fl__link:hover { color:#FFFFFF; }
  .fl__empty { padding:2rem var(--gutter); font-family:var(--f); font-size:0.8rem; color:var(--g5); }

  /* 4-COL GRID with 4:5 ratio enforced */
  .fg4 { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); }

  /* COLLABS */
  .hcl { border-bottom:1px solid var(--g2); }
  .hcl__head { display:flex; align-items:flex-end; justify-content:space-between; padding:1.75rem var(--gutter); border-bottom:1px solid var(--g2); }
  .hcl__title { font-size:clamp(1.1rem,2.2vw,1.7rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.01em; margin-top:0.3rem; }
  .cgrid { display:grid; grid-template-columns:2fr 1fr 1fr; grid-template-rows:260px 180px; gap:var(--gap); background:var(--g2); }
  .cg { position:relative; overflow:hidden; display:block; text-decoration:none; background:var(--g1); }
  .cg-0 { grid-row:span 2; }
  .cg-3 { grid-column:2/span 2; }
  .cg__img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.55s ease; filter:grayscale(0.2); }
  .cg:hover .cg__img { transform:scale(1.04); filter:grayscale(0); }
  .cg__dim { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.88) 0%,transparent 55%); }
  .cg__info { position:absolute; bottom:1rem; left:1.25rem; }
  .cg__type { display:block; font-family:var(--f); font-size:0.5rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.45); margin-bottom:0.25rem; font-weight:300; }
  .cg__name { font-family:var(--f); font-weight:500; font-size:clamp(0.9rem,2vw,1.5rem); color:#FFFFFF; letter-spacing:-0.01em; }

  /* STATS — compact */
  .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .stat { background:#000; padding:1.1rem var(--gutter); display:flex; flex-direction:column; gap:0.25rem; }
  .stat__n { font-family:var(--f); font-weight:500; font-size:clamp(1.6rem,3vw,2.5rem); color:#FFFFFF; line-height:1; letter-spacing:-0.02em; }
  .stat__n em { color:var(--g3); font-style:normal; }

  /* FOOTER */
  .foot { padding:2rem var(--gutter); display:flex; flex-direction:column; gap:1.25rem; }
  .foot__top { display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:clamp(1rem,2vw,1.7rem); color:#FFFFFF; letter-spacing:0.06em; text-transform:uppercase; }
  .foot__sub   { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); margin-top:0.3rem; }
  .foot__nav   { display:flex; gap:1.75rem; flex-wrap:wrap; }
  .foot__nav a { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; }
  .foot__nav a:hover { color:#FFFFFF; }
  .foot__copy  { font-family:var(--f); font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--g2); }

  /* RESPONSIVE */
  @media(max-width:900px){
    .about { grid-template-columns:1fr; }
    .about__left { border-right:none; border-bottom:1px solid var(--g2); }
    .fg4 { grid-template-columns:repeat(2,1fr); }
    .cgrid { grid-template-columns:1fr 1fr; grid-template-rows:auto; }
    .cg-0 { grid-row:auto; grid-column:span 2; }
    .cg-3 { grid-column:span 2; }
    .stats { grid-template-columns:repeat(2,1fr); }
    .foot__top { flex-direction:column; align-items:flex-start; }
  }
  /* 2-col on mobile — per spec */
  @media(max-width:560px){ .fg4 { grid-template-columns:repeat(2,1fr); } }
</style>
