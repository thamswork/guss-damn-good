---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const collabs = await getCollection('collabs').catch(() => []);
  return collabs.map(c => ({
    params: { slug: c.id },
    props: { collab: c.data },
  }));
}

const { collab } = Astro.props;
const hasHero = collab.hero_video || collab.hero_image;
const wsImgs  = collab.work_station_images || [];
const hasWS   = wsImgs.length > 0 || collab.work_station_video;
---

<BaseLayout title={`${collab.partner_name} × Guss Damn Good`}>
  <Nav/>

  <!-- HERO — full bleed, always shows something -->
  <div class="ch">
    {collab.hero_video
      ? <video class="ch__m" src={collab.hero_video} autoplay muted loop playsinline/>
      : collab.hero_image
        ? <img class="ch__m" src={collab.hero_image} alt={collab.partner_name}/>
        : <div class="ch__m ch__blank"/>
    }
    <div class="ch__dim"/>
    <div class="ch__meta">
      <span class="eyebrow">{(collab.project_type||'').replace(/_/g,' ')} · {collab.year}</span>
      <h1 class="ch__title">{collab.partner_name} × Guss</h1>
      {collab.flavor_name && <p class="ch__flavor">{collab.flavor_name}</p>}
    </div>
  </div>

  <!-- CASE STUDY BODY -->
  <div class="cs">
    <div class="cs__main">
      {collab.intro && (
        <section class="cs__s">
          <p class="eyebrow" style="margin-bottom:0.6rem;">The Collaboration</p>
          <p class="cs__lead">{collab.intro}</p>
        </section>
      )}

      {(collab.challenge || collab.process) && (
        <section class="cs__two">
          {collab.challenge && (
            <div>
              <p class="eyebrow" style="margin-bottom:0.6rem;">The Brief</p>
              <p class="cs__body">{collab.challenge}</p>
            </div>
          )}
          {collab.process && (
            <div>
              <p class="eyebrow" style="margin-bottom:0.6rem;">Story-to-Flavor</p>
              <p class="cs__body">{collab.process}</p>
            </div>
          )}
        </section>
      )}

      {collab.result && (
        <section class="cs__s cs__result">
          <p class="eyebrow" style="margin-bottom:0.6rem;">The Result</p>
          <p class="cs__lead">{collab.result}</p>
        </section>
      )}
    </div>

    <aside class="cs__side">
      {[
        { label:'Partner',  val: collab.partner_name },
        { label:'Type',     val: (collab.project_type||'').replace(/_/g,' ') },
        { label:'Year',     val: collab.year },
        { label:'Flavor',   val: collab.flavor_name },
      ].filter(r=>r.val).map(r=>(
        <div class="cs__card">
          <p class="eyebrow" style="margin-bottom:0.25rem;">{r.label}</p>
          <p class="cs__val">{r.val}</p>
        </div>
      ))}
      <div class="cs__cta">
        <p class="cs__cta-h">Start a collaboration</p>
        <p class="cs__cta-b">Custom flavors, branded products, events and campaigns.</p>
        <a href="mailto:collab@gussdamngood.com" class="cs__cta-btn">Get in touch →</a>
      </div>
    </aside>
  </div>

  <!-- WORK STATION — only if content exists -->
  {hasWS && (
    <section class="ws">
      <div class="ws__head">
        <div>
          <p class="eyebrow" style="margin-bottom:0.5rem;">Work Station</p>
          <h2 class="ws__title">Where it gets made.</h2>
        </div>
        <p class="ws__sub">Every collaboration begins in our kitchen — where ingredients, stories, and instincts collide until something damn good emerges.</p>
      </div>

      <div class="ws__steps">
        {["Brief & Story Gathering","Flavor Prototyping","Tasting & Refinement","Production & Launch"].map((s,i)=>(
          <div class="ws__step">
            <span class="ws__n">0{i+1}</span>
            <h3 class="ws__st">{s}</h3>
          </div>
        ))}
      </div>

      <!-- PHOTO/VIDEO GRID — handles any number of images -->
      <div class={`ws__grid ws__grid--${Math.min(wsImgs.length + (collab.work_station_video?1:0), 4)}`}>
        {collab.work_station_video && (
          <div class="ws__item ws__item--hero">
            <video src={collab.work_station_video} autoplay muted loop playsinline class="ws__fill"/>
          </div>
        )}
        {wsImgs.map((src,i)=>(
          <div class={`ws__item${i===0&&!collab.work_station_video?' ws__item--hero':''}`}>
            <img src={src} alt={`Process ${i+1}`} class="ws__fill" loading="lazy"/>
          </div>
        ))}
      </div>
    </section>
  )}

  <div class="cs__foot">
    <a href="/collabs" class="cs__back">← All collaborations</a>
    <a href="mailto:collab@gussdamngood.com" class="cs__contact">Start your collaboration ↗</a>
  </div>

  <footer class="foot">
    <div class="foot__top">
      <p class="foot__brand">Guss Damn Good</p>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/collabs">All Collabs</a>
        <a href="/story">Story</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  /* HERO */
  .ch { position:relative; height:70vh; min-height:480px; overflow:hidden; margin-top:var(--nav-h); }
  .ch__m { width:100%; height:100%; object-fit:cover; display:block; }
  .ch__blank { width:100%; height:100%; background:linear-gradient(135deg,var(--g1) 0%,var(--g2) 100%); }
  .ch__dim { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.96) 0%,rgba(0,0,0,0.2) 60%,transparent 100%); }
  .ch__meta { position:absolute; bottom:3rem; left:var(--gutter); right:var(--gutter); }
  .ch__title { font-size:clamp(2.5rem,7vw,6rem); font-weight:600; color:#FFFFFF; letter-spacing:-0.02em; margin-top:0.75rem; line-height:1; }
  .ch__flavor { font-family:var(--f); font-size:0.88rem; color:rgba(255,255,255,0.5); margin-top:0.5rem; font-weight:300; }

  /* CASE STUDY */
  .cs { display:grid; grid-template-columns:1fr 300px; border-bottom:1px solid var(--g2); }
  .cs__main { padding:clamp(3rem,5vw,5rem) var(--gutter); display:flex; flex-direction:column; gap:3rem; border-right:1px solid var(--g2); }
  .cs__s { display:flex; flex-direction:column; gap:0.75rem; }
  .cs__two { display:grid; grid-template-columns:1fr 1fr; gap:2.5rem; padding-top:2.5rem; border-top:1px solid var(--g2); }
  .cs__result { padding-top:2.5rem; border-top:1px solid var(--g2); }
  .cs__lead { font-family:var(--f); font-size:1.05rem; color:#FFFFFF; line-height:1.85; font-weight:300; }
  .cs__body { font-family:var(--f); font-size:0.9rem; color:rgba(255,255,255,0.65); line-height:1.85; font-weight:300; }

  .cs__side { padding:2.5rem 1.75rem; display:flex; flex-direction:column; }
  .cs__card { padding:0.9rem 0; border-bottom:1px solid var(--g2); }
  .cs__val  { font-family:var(--f); font-size:0.92rem; color:#FFFFFF; font-weight:300; margin-top:0.25rem; text-transform:capitalize; }
  .cs__cta  { padding-top:1.75rem; display:flex; flex-direction:column; gap:0.65rem; }
  .cs__cta-h { font-family:var(--f); font-weight:500; font-size:1.05rem; color:#FFFFFF; }
  .cs__cta-b { font-family:var(--f); font-size:0.8rem; color:rgba(255,255,255,0.45); line-height:1.65; font-weight:300; }
  .cs__cta-btn { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:#000; background:#FFFFFF; padding:0.72rem 1.4rem; text-decoration:none; text-align:center; font-weight:500; transition:opacity 0.22s; display:block; }
  .cs__cta-btn:hover { opacity:0.85; }

  /* WORK STATION */
  .ws { border-bottom:1px solid var(--g2); }
  .ws__head { display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding:clamp(2.5rem,5vw,4.5rem) var(--gutter); border-bottom:1px solid var(--g2); align-items:end; }
  .ws__title { font-size:clamp(1.6rem,3.5vw,3rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.02em; margin-top:0.5rem; }
  .ws__sub { font-family:var(--f); font-size:0.9rem; color:rgba(255,255,255,0.55); line-height:1.8; font-weight:300; }
  .ws__steps { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .ws__step { background:var(--g1); padding:1.75rem 1.5rem; }
  .ws__n { font-family:var(--f); font-size:0.5rem; letter-spacing:0.25em; color:var(--g3); font-weight:400; display:block; margin-bottom:0.5rem; }
  .ws__st { font-family:var(--f); font-weight:500; font-size:0.95rem; color:#FFFFFF; letter-spacing:-0.01em; }

  /* PHOTO GRID — flexible, handles 1-6 images */
  .ws__grid { display:grid; gap:var(--gap); background:var(--g2); }
  .ws__grid--1 { grid-template-columns:1fr; }
  .ws__grid--2 { grid-template-columns:1fr 1fr; }
  .ws__grid--3 { grid-template-columns:2fr 1fr; grid-template-rows:1fr 1fr; }
  .ws__grid--4 { grid-template-columns:2fr 1fr; grid-template-rows:1fr 1fr; }
  .ws__item { overflow:hidden; background:#080808; aspect-ratio:4/3; }
  .ws__item--hero { aspect-ratio:16/9; }
  .ws__grid--3 .ws__item--hero,
  .ws__grid--4 .ws__item--hero { grid-row:span 2; aspect-ratio:unset; }
  .ws__fill { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.5s ease; }
  .ws__item:hover .ws__fill { transform:scale(1.04); }

  /* FOOTER STRIP */
  .cs__foot { display:flex; align-items:center; justify-content:space-between; padding:2rem var(--gutter); border-bottom:1px solid var(--g2); flex-wrap:wrap; gap:1rem; }
  .cs__back { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; font-weight:300; }
  .cs__back:hover { color:#FFFFFF; }
  .cs__contact { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:#000; background:#FFFFFF; padding:0.65rem 1.5rem; text-decoration:none; font-weight:500; transition:opacity 0.22s; }
  .cs__contact:hover { opacity:0.85; }

  .foot { padding:2rem var(--gutter); display:flex; flex-direction:column; gap:1rem; border-top:1px solid var(--g2); }
  .foot__top { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:1.1rem; color:#FFFFFF; letter-spacing:0.06em; text-transform:uppercase; }
  .foot__nav { display:flex; gap:2rem; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; }
  .foot__nav a:hover { color:#FFFFFF; }
  .foot__copy { font-family:var(--f); font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:768px){
    .cs { grid-template-columns:1fr; }
    .cs__main { border-right:none; border-bottom:1px solid var(--g2); }
    .cs__two { grid-template-columns:1fr; }
    .ws__head { grid-template-columns:1fr; }
    .ws__steps { grid-template-columns:repeat(2,1fr); }
    .ws__grid--3,.ws__grid--4 { grid-template-columns:1fr 1fr; grid-template-rows:auto; }
    .ws__grid--3 .ws__item--hero,
    .ws__grid--4 .ws__item--hero { grid-row:auto; aspect-ratio:16/9; }
  }
</style>
