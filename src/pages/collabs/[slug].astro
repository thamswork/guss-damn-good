---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const collabs = await getCollection('collabs').catch(() => []);
  return collabs.map(c => ({
    params: { slug: c.id },
    props: { collab: c.data, id: c.id },
  }));
}

const { collab, id } = Astro.props;
---

<BaseLayout title={`${collab.partner_name} × Guss Damn Good`}>
  <Nav/>

  <!-- HERO -->
  <div class="ch" style="margin-top:var(--nav-h);">
    {collab.hero_video
      ? <video class="ch__media" src={collab.hero_video} autoplay muted loop playsinline/>
      : collab.hero_image
        ? <img class="ch__media" src={collab.hero_image} alt={collab.partner_name}/>
        : <div class="ch__media ch__ph"/>
    }
    <div class="ch__dim"/>
    <div class="ch__meta">
      <span class="eyebrow">{collab.project_type?.replace(/_/g,' ')} · {collab.year}</span>
      <h1 class="ch__title">{collab.partner_name} × Guss</h1>
      {collab.flavor_name && <p class="ch__flavor">{collab.flavor_name}</p>}
    </div>
  </div>

  <!-- CASE STUDY -->
  <div class="cs">
    <div class="cs__main">
      {collab.intro && (
        <section class="cs__sec">
          <p class="eyebrow" style="margin-bottom:0.75rem;">The Collaboration</p>
          <p class="cs__lead">{collab.intro}</p>
        </section>
      )}
      {(collab.challenge || collab.process) && (
        <section class="cs__two">
          {collab.challenge && (
            <div>
              <p class="eyebrow" style="margin-bottom:0.75rem;">The Brief</p>
              <p class="cs__body">{collab.challenge}</p>
            </div>
          )}
          {collab.process && (
            <div>
              <p class="eyebrow" style="margin-bottom:0.75rem;">Story-to-Flavor</p>
              <p class="cs__body">{collab.process}</p>
            </div>
          )}
        </section>
      )}
      {collab.result && (
        <section class="cs__sec cs__result">
          <p class="eyebrow" style="margin-bottom:0.75rem;">The Result</p>
          <p class="cs__lead">{collab.result}</p>
        </section>
      )}
    </div>

    <aside class="cs__side">
      <div class="cs__card">
        <p class="eyebrow" style="margin-bottom:0.3rem;">Partner</p>
        <p class="cs__val">{collab.partner_name}</p>
      </div>
      {collab.project_type && (
        <div class="cs__card">
          <p class="eyebrow" style="margin-bottom:0.3rem;">Type</p>
          <p class="cs__val">{collab.project_type.replace(/_/g,' ')}</p>
        </div>
      )}
      {collab.year && (
        <div class="cs__card">
          <p class="eyebrow" style="margin-bottom:0.3rem;">Year</p>
          <p class="cs__val">{collab.year}</p>
        </div>
      )}
      {collab.flavor_name && (
        <div class="cs__card">
          <p class="eyebrow" style="margin-bottom:0.3rem;">Flavor</p>
          <p class="cs__val">{collab.flavor_name}</p>
        </div>
      )}
      <div class="cs__cta">
        <p class="cs__cta-title">Start a collaboration</p>
        <p class="cs__cta-body">Custom flavors, branded products, events and campaigns.</p>
        <a href="mailto:collab@gussdamngood.com" class="cs__cta-btn">Get in touch →</a>
      </div>
    </aside>
  </div>

  <!-- WORK STATION -->
  {(collab.work_station_images?.length > 0 || collab.work_station_video) && (
    <section class="ws">
      <div class="ws__head">
        <div>
          <p class="eyebrow" style="margin-bottom:0.5rem;">Work Station</p>
          <h2 class="ws__title">Where it gets made.</h2>
        </div>
        <p class="ws__sub">Every collaboration begins in our kitchen — where ingredients, stories, and instincts collide.</p>
      </div>

      <div class="ws__steps">
        {["Brief & Story Gathering","Flavor Prototyping","Tasting & Refinement","Production & Launch"].map((s,i)=>(
          <div class="ws__step">
            <span class="ws__n">0{i+1}</span>
            <h3 class="ws__st">{s}</h3>
          </div>
        ))}
      </div>

      {(collab.work_station_images?.length > 0 || collab.work_station_video) && (
        <div class="ws__media">
          <div class="ws__hero">
            {collab.work_station_video
              ? <video src={collab.work_station_video} autoplay muted loop playsinline class="ws__fill"/>
              : collab.work_station_images?.[0]
                ? <img src={collab.work_station_images[0]} alt="Work station" class="ws__fill" loading="lazy"/>
                : null
            }
          </div>
          <div class="ws__grid">
            {(collab.work_station_images || []).slice(1,4).map((src,i) => (
              <div class="ws__cell">
                <img src={src} alt={`Process ${i+2}`} class="ws__fill" loading="lazy"/>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <div class="cs__foot">
    <a href="/collabs" class="cs__back">← All collaborations</a>
    <a href="mailto:collab@gussdamngood.com" class="cs__contact">Start your collaboration ↗</a>
  </div>

  <footer class="foot">
    <div class="foot__top">
      <p class="foot__brand">Guss Damn Good</p>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/collabs">All Collabs</a>
        <a href="/story">Story</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  .ch { position:relative; height:65vh; min-height:420px; overflow:hidden; }
  .ch__media { width:100%; height:100%; object-fit:cover; display:block; }
  .ch__ph { background:var(--g2); }
  .ch__dim { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.95) 0%,rgba(0,0,0,0.25) 55%); }
  .ch__meta { position:absolute; bottom:2.5rem; left:var(--gutter); right:var(--gutter); }
  .ch__title { font-size:clamp(2rem,6vw,5rem); font-weight:600; color:#FFFFFF; letter-spacing:-0.02em; margin-top:0.5rem; line-height:1; }
  .ch__flavor { font-family:var(--f); font-size:0.85rem; color:rgba(255,255,255,0.5); margin-top:0.5rem; font-weight:300; }

  .cs { display:grid; grid-template-columns:1fr 280px; border-bottom:1px solid var(--g2); }
  .cs__main { padding:clamp(3rem,5vw,5rem) var(--gutter); display:flex; flex-direction:column; gap:2.5rem; border-right:1px solid var(--g2); }
  .cs__sec { display:flex; flex-direction:column; gap:0.75rem; }
  .cs__two { display:grid; grid-template-columns:1fr 1fr; gap:2rem; padding-top:2rem; border-top:1px solid var(--g2); }
  .cs__result { padding-top:2rem; border-top:1px solid var(--g2); }
  .cs__lead { font-family:var(--f); font-size:1rem; color:#FFFFFF; line-height:1.85; font-weight:300; opacity:0.85; }
  .cs__body { font-family:var(--f); font-size:0.88rem; color:#FFFFFF; line-height:1.85; font-weight:300; opacity:0.6; }

  .cs__side { padding:3rem 1.75rem; display:flex; flex-direction:column; gap:0; }
  .cs__card { padding:1rem 0; border-bottom:1px solid var(--g2); }
  .cs__val  { font-family:var(--f); font-size:0.9rem; color:#FFFFFF; font-weight:300; margin-top:0.25rem; text-transform:capitalize; }
  .cs__cta  { padding-top:1.75rem; display:flex; flex-direction:column; gap:0.65rem; }
  .cs__cta-title { font-family:var(--f); font-weight:500; font-size:1rem; color:#FFFFFF; }
  .cs__cta-body  { font-family:var(--f); font-size:0.78rem; color:rgba(255,255,255,0.45); line-height:1.6; font-weight:300; }
  .cs__cta-btn   { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:#000000; background:#FFFFFF; padding:0.65rem 1.25rem; text-decoration:none; text-align:center; font-weight:500; transition:opacity 0.22s; }
  .cs__cta-btn:hover { opacity:0.85; }

  .ws { border-bottom:1px solid var(--g2); }
  .ws__head { display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding:clamp(3rem,5vw,5rem) var(--gutter); border-bottom:1px solid var(--g2); align-items:end; }
  .ws__title { font-size:clamp(1.5rem,3.5vw,3rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.02em; margin-top:0.5rem; }
  .ws__sub { font-family:var(--f); font-size:0.88rem; color:rgba(255,255,255,0.55); line-height:1.8; font-weight:300; }
  .ws__steps { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .ws__step { background:var(--g1); padding:1.75rem 1.5rem; }
  .ws__n { font-family:var(--f); font-size:0.5rem; letter-spacing:0.25em; color:var(--g3); font-weight:400; display:block; margin-bottom:0.5rem; }
  .ws__st { font-family:var(--f); font-weight:500; font-size:0.9rem; color:#FFFFFF; letter-spacing:-0.01em; }
  .ws__media { display:grid; grid-template-columns:2fr 1fr; gap:var(--gap); background:var(--g2); }
  .ws__hero,.ws__cell { overflow:hidden; background:#080808; }
  .ws__hero { aspect-ratio:4/3; }
  .ws__grid { display:grid; grid-template-rows:repeat(3,1fr); gap:var(--gap); }
  .ws__cell { aspect-ratio:unset; }
  .ws__fill { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.5s ease; }
  .ws__hero:hover .ws__fill,.ws__cell:hover .ws__fill { transform:scale(1.04); }

  .cs__foot { display:flex; align-items:center; justify-content:space-between; padding:2rem var(--gutter); border-bottom:1px solid var(--g2); flex-wrap:wrap; gap:1rem; }
  .cs__back    { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; font-weight:300; }
  .cs__back:hover { color:#FFFFFF; }
  .cs__contact { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:#000000; background:#FFFFFF; padding:0.65rem 1.5rem; text-decoration:none; font-weight:500; transition:opacity 0.22s; }
  .cs__contact:hover { opacity:0.85; }

  .foot { padding:2rem var(--gutter); display:flex; flex-direction:column; gap:1rem; border-top:1px solid var(--g2); }
  .foot__top { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:1.1rem; color:#FFFFFF; letter-spacing:0.06em; text-transform:uppercase; }
  .foot__nav { display:flex; gap:2rem; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; }
  .foot__nav a:hover { color:#FFFFFF; }
  .foot__copy { font-family:var(--f); font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:768px){
    .cs { grid-template-columns:1fr; }
    .cs__main { border-right:none; border-bottom:1px solid var(--g2); }
    .cs__two { grid-template-columns:1fr; }
    .ws__head { grid-template-columns:1fr; }
    .ws__steps { grid-template-columns:repeat(2,1fr); }
    .ws__media { grid-template-columns:1fr; }
    .ws__hero { aspect-ratio:16/9; }
    .ws__grid { grid-template-rows:auto; grid-template-columns:repeat(3,1fr); }
  }
</style>
