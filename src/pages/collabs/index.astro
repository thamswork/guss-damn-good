---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

const collabs = [
  { slug:"rimowa",    name:"RIMOWA",    type:"Collab Flavor", year:2023, img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80",  flavor:"Papaya Sorbet & Mint Cookie Chip" },
  { slug:"valentino", name:"Valentino", type:"Collab Flavor", year:2023, img:"https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=800&q=80", flavor:"Greek Yogurt Lemon & Black Sesame" },
  { slug:"rimowa",    name:"Hermes",    type:"Collab Flavor", year:2022, img:"https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=800&q=80",  flavor:"Exclusive Edition" },
  { slug:"rimowa",    name:"La Mer",    type:"Campaign",      year:2022, img:"https://images.unsplash.com/photo-1570194065650-d99fb4b8ccb4?w=800&q=80", flavor:"Limited Drop" },
  { slug:"rimowa",    name:"SCRUBB",    type:"Campaign",      year:2024, img:"https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=800&q=80", flavor:"National Ice Cream Month" },
  { slug:"rimowa",    name:"Wedding",   type:"Catering",      year:2024, img:"https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=800&q=80", flavor:"Custom Catering" },
];
---
<BaseLayout title="Collaborations — Guss Damn Good">
  <Nav/>

  <header class="clh reveal">
    <div class="clh__left">
      <p class="eyebrow" style="margin-bottom:1rem;">100+ Brand Partners</p>
      <h1 class="clh__title">Every collab<br/>tells a story.</h1>
    </div>
    <div class="clh__right">
      <p class="clh__body">From luxury fashion houses to local super brands — we craft feelings through ice cream for brands across every world.</p>
      <div class="clh__types">
        {["Collab Flavors","OEM / ODM","Event Catering","Campaigns","Weddings"].map(t=><span class="clh__type">{t}</span>)}
      </div>
      <a href="mailto:collab@gussdamngood.com" class="clh__cta">Start a collaboration ↗</a>
    </div>
  </header>

  <div class="clgrid">
    {collabs.map((c,i)=>(
      <a href={`/collabs/${c.slug}`} class={`clc clc-${i} reveal reveal-delay-${(i%3)+1}`}>
        <img src={c.img} alt={c.name} class="clc__img" loading={i<2?'eager':'lazy'}/>
        <div class="clc__dim"/>
        <div class="clc__info">
          <span class="clc__type">{c.type} · {c.year}</span>
          <h2 class="clc__name">{c.name}</h2>
          {c.flavor && <p class="clc__flavor">{c.flavor}</p>}
        </div>
      </a>
    ))}
  </div>

  <section class="clband reveal">
    <div class="clband__text">
      <h2 class="clband__title">Let's craft something damn good together.</h2>
      <p class="clband__body">Custom flavors, OEM product lines, event catering, campaign drops — we've done it all. We handle everything from the kitchen to the moment it reaches the guest.</p>
    </div>
    <div class="clband__actions">
      <a href="mailto:collab@gussdamngood.com" class="clband__btn">Email us to collaborate</a>
      <a href="/story" class="clband__link">Read our story</a>
    </div>
  </section>

  <footer class="foot">
    <div class="foot__top">
      <p class="foot__brand">Guss Damn Good</p>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/story">Story</a>
        <a href="/locations">Find Us</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  .clh { display:grid; grid-template-columns:1fr 1fr; min-height:55vh; border-bottom:1px solid var(--g2); }
  .clh__left { padding:8rem var(--gutter) 4rem; border-right:1px solid var(--g2); display:flex; flex-direction:column; justify-content:flex-end; gap:1rem; }
  .clh__title { font-size:clamp(2.5rem,7vw,6rem); font-weight:500; color:var(--white); letter-spacing:-0.02em; line-height:0.95; }
  .clh__right { padding:8rem var(--gutter) 4rem; display:flex; flex-direction:column; justify-content:flex-end; gap:1.5rem; }
  .clh__body { font-family:var(--f); font-size:0.85rem; color:var(--g5); line-height:1.8; font-weight:300; max-width:380px; }
  .clh__types { display:flex; gap:0.4rem; flex-wrap:wrap; }
  .clh__type { font-family:var(--f); font-size:0.5rem; letter-spacing:0.15em; text-transform:uppercase; padding:0.25rem 0.65rem; border:1px solid var(--g2); color:var(--g4); font-weight:300; }
  .clh__cta { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--white); text-decoration:none; font-weight:400; border-bottom:1px solid var(--g3); padding-bottom:2px; align-self:flex-start; transition:border-color 0.22s; }
  .clh__cta:hover { border-color:var(--white); }

  .clgrid { display:grid; grid-template-columns:2fr 1fr 1fr; grid-template-rows:320px 200px; gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .clc { position:relative; overflow:hidden; display:block; text-decoration:none; background:var(--g1); }
  .clc-0 { grid-row:span 2; }
  .clc-3 { grid-column:2/span 2; }
  .clc__img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.55s ease; filter:grayscale(0.2); }
  .clc:hover .clc__img { transform:scale(1.04); filter:grayscale(0); }
  .clc__dim { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.9) 0%,transparent 55%); }
  .clc__info { position:absolute; bottom:1.25rem; left:1.25rem; }
  .clc__type { display:block; font-family:var(--f); font-size:0.48rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.38); margin-bottom:0.3rem; font-weight:300; }
  .clc__name { font-family:var(--f); font-weight:500; font-size:clamp(1rem,2.5vw,1.9rem); color:var(--white); letter-spacing:-0.01em; }
  .clc__flavor { font-family:var(--f); font-size:0.7rem; color:rgba(255,255,255,0.4); margin-top:0.2rem; font-weight:300; }

  .clband { display:flex; align-items:center; justify-content:space-between; gap:3rem; padding:clamp(3rem,6vw,5rem) var(--gutter); border-bottom:1px solid var(--g2); flex-wrap:wrap; }
  .clband__text { max-width:480px; display:flex; flex-direction:column; gap:1rem; }
  .clband__title { font-size:clamp(1.4rem,3vw,2.5rem); font-weight:400; color:var(--white); letter-spacing:-0.015em; line-height:1.15; }
  .clband__body { font-family:var(--f); font-size:0.82rem; color:var(--g5); line-height:1.8; font-weight:300; }
  .clband__actions { display:flex; flex-direction:column; gap:0.75rem; flex-shrink:0; }
  .clband__btn  { font-family:var(--f); font-size:0.55rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--black); background:var(--white); padding:0.7rem 1.6rem; text-decoration:none; font-weight:500; text-align:center; transition:opacity 0.22s; }
  .clband__btn:hover { opacity:0.85; }
  .clband__link { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); border:1px solid var(--g2); padding:0.7rem 1.6rem; text-decoration:none; text-align:center; font-weight:300; transition:all 0.22s; }
  .clband__link:hover { border-color:var(--white); color:var(--white); }

  .foot { padding:2.5rem var(--gutter); display:flex; flex-direction:column; gap:1.25rem; border-top:1px solid var(--g2); }
  .foot__top { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:clamp(1rem,1.8vw,1.6rem); color:var(--white); letter-spacing:0.06em; text-transform:uppercase; }
  .foot__nav   { display:flex; gap:2rem; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; font-weight:300; transition:color 0.22s; }
  .foot__nav a:hover { color:var(--white); }
  .foot__copy  { font-family:var(--f); font-size:0.46rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:768px){
    .clh { grid-template-columns:1fr; min-height:auto; }
    .clh__left { border-right:none; border-bottom:1px solid var(--g2); }
    .clgrid { grid-template-columns:1fr 1fr; grid-template-rows:auto; }
    .clc-0 { grid-row:auto; grid-column:span 2; aspect-ratio:16/9; }
    .clc-3 { grid-column:span 2; }
    .clband { flex-direction:column; align-items:flex-start; }
    .clband__actions { width:100%; }
    .clband__btn,.clband__link { text-align:center; }
  }
</style>
