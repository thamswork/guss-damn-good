---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

const cmsLocations = await getCollection('locations').catch(() => []);

const fallback = [
  { name:"Siam Paragon",         address:"991 Rama I Rd, Pathum Wan",             hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com/?q=Siam+Paragon",     thumb:"https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&q=70", formats:["Scoop","Sundae","Shake","Cake"], lat:13.7462, lng:100.5347 },
  { name:"Central World",        address:"4/1 Rama I Rd, Pathum Wan",             hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com/?q=CentralWorld",     thumb:"https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?w=600&q=70", formats:["Scoop","Sundae","Soft Serve"],  lat:13.7470, lng:100.5394 },
  { name:"EmQuartier",           address:"689 Sukhumvit Rd, Khlong Toei",         hours:"10:00–22:00", delivery:false, maps:"https://maps.google.com/?q=EmQuartier",       thumb:"https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?w=600&q=70", formats:["Scoop","Sundae","Shake"],       lat:13.7302, lng:100.5696 },
  { name:"The Mall Ngamwongwan", address:"Ngam Wong Wan Rd, Nonthaburi",          hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com/?q=The+Mall+Ngamwongwan", thumb:"https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=600&q=70", formats:["Scoop","Sundae"],         lat:13.8451, lng:100.5543 },
  { name:"Central Chidlom",      address:"1027 Phloen Chit Rd, Lumpini",          hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com/?q=Central+Chidlom",  thumb:"https://images.unsplash.com/photo-1604719312566-8912e9227c6a?w=600&q=70", formats:["Scoop","Cake"],              lat:13.7433, lng:100.5402 },
  { name:"Terminal 21 Asok",     address:"88 Sukhumvit Soi 19, Watthana",         hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com/?q=Terminal+21+Asok", thumb:"https://images.unsplash.com/photo-1519999482648-25049ddd37b1?w=600&q=70", formats:["Scoop","Sundae","Popsicle"],  lat:13.7374, lng:100.5604 },
  { name:"Mega Bangna",          address:"39 Bangna-Trad Rd, Bang Phli",          hours:"10:00–22:00", delivery:false, maps:"https://maps.google.com/?q=Mega+Bangna",      thumb:"https://images.unsplash.com/photo-1528698827591-e19ccd7bc23d?w=600&q=70", formats:["Scoop","Sundae","Soft Serve"], lat:13.6602, lng:100.6654 },
  { name:"Central Pinklao",      address:"7/222 Barommaratchachonnani Rd",         hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com/?q=Central+Pinklao",  thumb:"https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=600&q=70", formats:["Scoop"],                     lat:13.7739, lng:100.4775 },
  { name:"ICONSIAM",             address:"299 Charoen Nakhon Rd, Khlong Ton Sai", hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com/?q=ICONSIAM",         thumb:"https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=600&q=70", formats:["Scoop","Sundae","Shake","Cake"], lat:13.7271, lng:100.5105 },
];

const locations = cmsLocations.length > 0
  ? cmsLocations.map((l, i) => ({
      name:     l.data.name,
      address:  l.data.address || '',
      hours:    l.data.hours || '',
      delivery: l.data.delivery || false,
      maps:     l.data.maps || '#',
      thumb:    l.data.thumb || '',
      formats:  l.data.formats || [],
      lat:      fallback[i % fallback.length]?.lat || 13.75,
      lng:      fallback[i % fallback.length]?.lng || 100.52,
    }))
  : fallback;
---

<BaseLayout title="Find Us — Guss Damn Good">
  <Nav/>

  <header class="lh reveal">
    <div>
      <p class="eyebrow" style="margin-bottom:0.75rem;">18 Branches · Bangkok</p>
      <h1 class="lh__title">Find Us.</h1>
      <p class="lh__sub">Walk in. Scoop up. Feel something.</p>
    </div>
    <div class="lh__meta">
      <div class="lh__stat"><span class="lh__n">18</span><span class="eyebrow">Branches</span></div>
      <div class="lh__stat"><span class="lh__n">7</span><span class="eyebrow">Delivery zones</span></div>
    </div>
  </header>

  <div class="dbar">
    <span class="eyebrow">Delivery available at selected branches</span>
    <span class="dbar__apps">GrabFood · Foodpanda · LINE MAN</span>
  </div>

  <!-- 4-COL GRID desktop, 3-col mobile -->
  <div class="lgrid" id="lgrid">
    {locations.map((b, i) => (
      <div
        class={`lcard hover-lift reveal reveal-delay-${(i%4)+1}`}
        data-lat={b.lat}
        data-lng={b.lng}
        data-name={b.name}
        id={`loc-${i}`}
        onclick={`focusPin(${i})`}
      >
        <div class="lcard__thumb">
          <img src={b.thumb} alt={`${b.name} storefront`} loading="lazy"/>
          {b.delivery && <span class="lcard__dlv">Delivery</span>}
        </div>
        <div class="lcard__body">
          <h3 class="lcard__name">{b.name}</h3>
          <p class="lcard__addr">{b.address}</p>
          <div class="lcard__row"><span class="eyebrow" style="min-width:38px;">Hours</span><span class="lcard__v">{b.hours}</span></div>
          <div class="lcard__fmts">{b.formats.map(f=><span class="lcard__fmt">{f}</span>)}</div>
          <a href={b.maps} target="_blank" rel="noopener" class="lcard__map">View on Maps ↗</a>
        </div>
      </div>
    ))}
  </div>

  <!-- INTERACTIVE CHALK MAP -->
  <section class="mapbox" id="mapbox">
    <div class="map__head">
      <div>
        <p class="eyebrow" style="margin-bottom:0.5rem;">18 Locations</p>
        <h2 class="map__title">Bangkok, mapped.</h2>
      </div>
      <p class="map__sub">Click any pin or location card to zoom in.</p>
    </div>
    <div class="map__canvas" id="mapCanvas">
      <svg id="mapSvg" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
        <!-- Bangkok chalk-style outline -->
        <defs>
          <filter id="chalk">
            <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
            <feColorMatrix type="saturate" values="0"/>
            <feBlend in="SourceGraphic" mode="multiply"/>
          </filter>
          <radialGradient id="pinGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"/>
          </radialGradient>
        </defs>

        <!-- City grid lines — chalk aesthetic -->
        <g opacity="0.06" stroke="#FFFFFF" stroke-width="0.5">
          {Array.from({length:12},(_,i)=><line x1={i*70} y1="0" x2={i*70} y2="600"/>)}
          {Array.from({length:9},(_,i)=><line x1="0" y1={i*70} x2="800" y2={i*70}/>)}
        </g>

        <!-- Bangkok river (Chao Phraya) — rough chalk stroke -->
        <path d="M180 600 C200 520,185 480,195 420 C210 340,190 300,200 240 C215 160,205 100,220 40"
          fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="22" stroke-linecap="round"
          filter="url(#chalk)"/>
        <path d="M180 600 C200 520,185 480,195 420 C210 340,190 300,200 240 C215 160,205 100,220 40"
          fill="none" stroke="rgba(100,160,255,0.08)" stroke-width="14" stroke-linecap="round"/>

        <!-- Major roads -->
        <g stroke="rgba(255,255,255,0.07)" stroke-width="1.5" fill="none">
          <line x1="0" y1="280" x2="800" y2="280"/>
          <line x1="0" y1="350" x2="800" y2="350"/>
          <line x1="380" y1="0" x2="380" y2="600"/>
          <line x1="500" y1="0" x2="500" y2="600"/>
          <path d="M220 0 L220 600"/>
          <path d="M0 180 Q400 160 800 200"/>
        </g>

        <!-- Location pins — positioned by lat/lng mapped to SVG coords -->
        {locations.map((loc, i) => {
          // Map Bangkok lat/lng to SVG coords
          // Bangkok bounds: lat 13.60–13.90, lng 100.45–100.70
          const x = Math.round(((loc.lng - 100.45) / 0.25) * 700 + 50);
          const y = Math.round(((13.90 - loc.lat) / 0.30) * 520 + 40);
          return (
            <g class="map-pin" id={`pin-${i}`} onclick={`focusPin(${i})`} style="cursor:pointer;" transform={`translate(${x},${y})`}>
              <circle r="18" fill="url(#pinGlow)" class="pin-glow"/>
              <circle r="7" fill="#FFFFFF" opacity="0.9" class="pin-dot"/>
              <circle r="4" fill="#000000" class="pin-inner"/>
              <line x1="0" y1="7" x2="0" y2="18" stroke="#FFFFFF" stroke-width="1.5" opacity="0.6"/>
              <text x="0" y="-14" text-anchor="middle" font-family="'Montserrat',sans-serif" font-size="8" fill="#FFFFFF" opacity="0.7" font-weight="500">{loc.name.split(' ')[0]}</text>
            </g>
          );
        })}

        <!-- Compass -->
        <g transform="translate(755,45)" opacity="0.25">
          <circle r="16" fill="none" stroke="#FFFFFF" stroke-width="0.5"/>
          <text x="0" y="-18" text-anchor="middle" font-family="'Montserrat',sans-serif" font-size="7" fill="#FFFFFF">N</text>
          <line x1="0" y1="-10" x2="0" y2="10" stroke="#FFFFFF" stroke-width="0.8"/>
          <line x1="-10" y1="0" x2="10" y2="0" stroke="#FFFFFF" stroke-width="0.5"/>
        </g>
      </svg>

      <!-- Map tooltip -->
      <div id="mapTooltip" class="map__tip" style="display:none;">
        <p class="map__tip-name"></p>
        <p class="map__tip-addr"></p>
        <a class="map__tip-link" target="_blank" rel="noopener">Maps ↗</a>
      </div>
    </div>
  </section>

  <footer class="foot">
    <div class="foot__top">
      <div>
        <p class="foot__brand">Guss Damn Good</p>
        <p class="foot__sub">18 Branches · Bangkok, Thailand</p>
      </div>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/story">Story</a>
        <a href="/collabs">Collabs</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  /* HEADER */
  .lh { display:flex; align-items:flex-end; justify-content:space-between; padding:7rem var(--gutter) 2.5rem; border-bottom:1px solid var(--g2); gap:2rem; flex-wrap:wrap; }
  .lh__title { font-size:clamp(3rem,8vw,7rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.02em; line-height:0.95; margin:0.5rem 0; }
  .lh__sub { font-family:var(--f); font-size:0.82rem; color:rgba(255,255,255,0.5); font-weight:300; }
  .lh__meta { display:flex; gap:2.5rem; align-items:flex-end; flex-shrink:0; }
  .lh__stat { display:flex; flex-direction:column; gap:0.25rem; }
  .lh__n { font-family:var(--f); font-weight:400; font-size:clamp(1.8rem,4vw,3rem); color:#FFFFFF; line-height:1; letter-spacing:-0.02em; }

  /* DELIVERY BAR */
  .dbar { display:flex; align-items:center; justify-content:space-between; padding:0.8rem var(--gutter); border-bottom:1px solid var(--g2); background:var(--g1); flex-wrap:wrap; gap:0.75rem; }
  .dbar__apps { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:#FFFFFF; font-weight:400; }

  /* 4-COL GRID desktop */
  .lgrid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }

  .lcard { background:var(--g1); display:flex; flex-direction:column; cursor:pointer; transition:background 0.22s ease; }
  .lcard.active,.lcard:hover { background:#111; }

  /* 4:5 thumbnail */
  .lcard__thumb { position:relative; aspect-ratio:4/5; overflow:hidden; background:#080808; }
  .lcard__thumb img { width:100%; height:100%; object-fit:cover; display:block; filter:grayscale(0.1); transition:transform 0.5s ease, filter 0.4s ease; }
  .lcard:hover .lcard__thumb img,.lcard.active .lcard__thumb img { transform:scale(1.05); filter:grayscale(0); }
  .lcard__dlv { position:absolute; top:0.55rem; right:0.55rem; font-family:var(--f); font-size:0.46rem; letter-spacing:0.2em; text-transform:uppercase; background:#FFFFFF; color:#000000; padding:0.18rem 0.5rem; font-weight:500; }

  .lcard__body { padding:1rem 1rem 1.25rem; display:flex; flex-direction:column; gap:0.55rem; flex:1; }
  .lcard__name { font-family:var(--f); font-weight:600; font-size:clamp(0.85rem,1.5vw,1.1rem); color:#FFFFFF; letter-spacing:-0.01em; line-height:1.2; }
  .lcard__addr { font-family:var(--f); font-size:0.75rem; color:rgba(255,255,255,0.45); line-height:1.5; font-weight:300; }
  .lcard__row { display:flex; align-items:baseline; gap:0.6rem; padding-top:0.4rem; border-top:1px solid var(--g2); }
  .lcard__v { font-family:var(--f); font-size:0.75rem; color:#FFFFFF; font-weight:300; }
  .lcard__fmts { display:flex; gap:0.3rem; flex-wrap:wrap; }
  .lcard__fmt { font-family:var(--f); font-size:0.46rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--g4); border:1px solid var(--g2); padding:0.14rem 0.42rem; font-weight:300; }
  .lcard__map { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:#FFFFFF; text-decoration:none; font-weight:400; margin-top:auto; padding-top:0.65rem; border-top:1px solid var(--g2); transition:opacity 0.22s; display:block; }
  .lcard__map:hover { opacity:0.5; }

  /* MAP SECTION */
  .mapbox { border-bottom:1px solid var(--g2); }
  .map__head { display:flex; align-items:flex-end; justify-content:space-between; padding:2rem var(--gutter); border-bottom:1px solid var(--g2); flex-wrap:wrap; gap:1rem; }
  .map__title { font-size:clamp(1.5rem,3vw,2.5rem); font-weight:500; color:#FFFFFF; letter-spacing:-0.02em; margin-top:0.4rem; }
  .map__sub { font-family:var(--f); font-size:0.78rem; color:rgba(255,255,255,0.45); font-weight:300; }
  .map__canvas { position:relative; width:100%; aspect-ratio:4/3; background:#050505; overflow:hidden; }

  /* PINS */
  .map-pin { transition:transform 0.3s ease; }
  .map-pin:hover { transform:scale(1.3); }
  .map-pin.active .pin-dot { fill:#FFD700; r:9; }
  .map-pin.active .pin-inner { fill:#000; }
  .map-pin.active .pin-glow { r:28; }
  .pin-dot { transition:all 0.3s ease; }

  /* TOOLTIP */
  .map__tip { position:absolute; background:rgba(0,0,0,0.92); border:1px solid var(--g2); padding:0.75rem 1rem; pointer-events:none; min-width:160px; z-index:10; }
  .map__tip-name { font-family:var(--f); font-weight:500; font-size:0.82rem; color:#FFFFFF; margin-bottom:0.2rem; }
  .map__tip-addr { font-family:var(--f); font-size:0.65rem; color:rgba(255,255,255,0.5); font-weight:300; margin-bottom:0.4rem; line-height:1.4; }
  .map__tip-link { font-family:var(--f); font-size:0.5rem; letter-spacing:0.15em; text-transform:uppercase; color:#FFFFFF; text-decoration:none; pointer-events:all; }

  /* FOOTER */
  .foot { padding:2rem var(--gutter); display:flex; flex-direction:column; gap:1.25rem; border-top:1px solid var(--g2); }
  .foot__top { display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:clamp(1rem,2vw,1.6rem); color:#FFFFFF; letter-spacing:0.06em; text-transform:uppercase; }
  .foot__sub { font-family:var(--f); font-size:0.48rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--g4); margin-top:0.25rem; }
  .foot__nav { display:flex; gap:2rem; flex-wrap:wrap; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; }
  .foot__nav a:hover { color:#FFFFFF; }
  .foot__copy { font-family:var(--f); font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--g2); }

  /* RESPONSIVE */
  @media(max-width:900px){
    .lgrid { grid-template-columns:repeat(3,1fr); }
    .lcard__thumb { aspect-ratio:3/2; } /* horizontal on mobile */
  }
  @media(max-width:600px){
    .lgrid { grid-template-columns:repeat(3,1fr); }
    .lcard__thumb { aspect-ratio:1/1; }
    .lcard__body { padding:0.6rem 0.6rem 0.8rem; gap:0.35rem; }
    .lcard__name { font-size:0.75rem; }
    .lcard__addr,.lcard__row,.lcard__fmts,.lcard__map { display:none; }
    .lh { flex-direction:column; align-items:flex-start; }
  }
</style>

<script define:vars={{ locations }}>
  var activeCard = -1;
  var activePin  = -1;

  function clearActive() {
    document.querySelectorAll('.lcard').forEach(function(c){ c.classList.remove('active'); });
    document.querySelectorAll('.map-pin').forEach(function(p){ p.classList.remove('active'); });
  }

  function focusPin(i) {
    clearActive();
    activeCard = i;
    activePin  = i;

    var card = document.getElementById('loc-'+i);
    var pin  = document.getElementById('pin-'+i);

    if (card) {
      card.classList.add('active');
      card.scrollIntoView({ behavior:'smooth', block:'nearest' });
    }
    if (pin) {
      pin.classList.add('active');
    }

    var loc = locations[i];
    if (!loc) return;

    var tip  = document.getElementById('mapTooltip');
    var svg  = document.getElementById('mapSvg');
    if (!tip || !svg) return;

    // Position tooltip near pin
    var x = ((loc.lng - 100.45) / 0.25) * 700 + 50;
    var y = ((13.90 - loc.lat) / 0.30) * 520 + 40;
    var rect = svg.getBoundingClientRect();
    var vw = svg.viewBox.baseVal.width || 800;
    var vh = svg.viewBox.baseVal.height || 600;
    var px = (x / vw) * rect.width;
    var py = (y / vh) * rect.height;

    tip.style.display = 'block';
    tip.style.left = Math.min(px + 12, rect.width - 180) + 'px';
    tip.style.top  = Math.max(py - 80, 8) + 'px';
    tip.querySelector('.map__tip-name').textContent = loc.name;
    tip.querySelector('.map__tip-addr').textContent = loc.address;
    tip.querySelector('.map__tip-link').href = loc.maps;
  }

  // Close tooltip on canvas click away
  document.getElementById('mapCanvas')?.addEventListener('click', function(e) {
    if (!e.target.closest('.map-pin') && !e.target.closest('.map__tip')) {
      document.getElementById('mapTooltip').style.display = 'none';
      clearActive();
    }
  });

  window.focusPin = focusPin;
</script>
