---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const branches = [
  { name:"Siam Paragon",        address:"991 Rama I Rd, Pathum Wan",              hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=500&q=70", formats:["Scoop","Sundae","Shake","Cake"] },
  { name:"Central World",       address:"4/1 Rama I Rd, Pathum Wan",              hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?w=500&q=70", formats:["Scoop","Sundae","Soft Serve"] },
  { name:"EmQuartier",          address:"689 Sukhumvit Rd, Khlong Toei",          hours:"10:00–22:00", delivery:false, maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?w=500&q=70", formats:["Scoop","Sundae","Shake"] },
  { name:"The Mall Ngamwongwan",address:"Ngam Wong Wan Rd, Nonthaburi",           hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=500&q=70", formats:["Scoop","Sundae"] },
  { name:"Central Chidlom",     address:"1027 Phloen Chit Rd, Lumpini",          hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1604719312566-8912e9227c6a?w=500&q=70", formats:["Scoop","Cake"] },
  { name:"Terminal 21 Asok",    address:"88 Sukhumvit Soi 19, Watthana",          hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1519999482648-25049ddd37b1?w=500&q=70", formats:["Scoop","Sundae","Popsicle"] },
  { name:"Mega Bangna",         address:"39 Bangna-Trad Rd, Bang Phli",           hours:"10:00–22:00", delivery:false, maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1528698827591-e19ccd7bc23d?w=500&q=70", formats:["Scoop","Sundae","Soft Serve"] },
  { name:"Central Pinklao",     address:"7/222 Barommaratchachonnani Rd",          hours:"10:00–21:00", delivery:false, maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=500&q=70", formats:["Scoop"] },
  { name:"ICONSIAM",            address:"299 Charoen Nakhon Rd, Khlong Ton Sai",  hours:"10:00–22:00", delivery:true,  maps:"https://maps.google.com", thumb:"https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=500&q=70", formats:["Scoop","Sundae","Shake","Cake"] },
];
---

<BaseLayout title="Find Us — Guss Damn Good">
  <Nav/>

  <!-- HEADER -->
  <header class="lh reveal">
    <div>
      <p class="eyebrow" style="margin-bottom:1rem;">18 Branches · Bangkok</p>
      <h1 class="lh__title">Find Us.</h1>
      <p class="lh__sub">Walk in. Scoop up. Feel something.</p>
    </div>
    <div class="lh__meta">
      <div class="lh__stat"><span class="lh__n">18</span><span class="eyebrow">Branches</span></div>
      <div class="lh__stat"><span class="lh__n">7</span><span class="eyebrow">Delivery zones</span></div>
    </div>
  </header>

  <!-- DELIVERY INFO BAR -->
  <div class="dbar">
    <span class="eyebrow">Delivery available at selected branches</span>
    <span class="dbar__apps">GrabFood · Foodpanda · LINE MAN</span>
  </div>

  <!-- 3-COL GRID -->
  <div class="lgrid">
    {branches.map((b, i) => (
      <div class={`lcard hover-lift reveal reveal-delay-${(i % 3) + 1}`}>
        <!-- THUMBNAIL -->
        <div class="lcard__thumb">
          <img src={b.thumb} alt={`${b.name} storefront`} loading="lazy"/>
          {b.delivery && <span class="lcard__dlv">Delivery</span>}
        </div>
        <!-- INFO -->
        <div class="lcard__body">
          <h3 class="lcard__name">{b.name}</h3>
          <p class="lcard__addr">{b.address}</p>
          <div class="lcard__rows">
            <div class="lcard__row"><span class="eyebrow" style="min-width:40px;">Hours</span><span class="lcard__v">{b.hours}</span></div>
          </div>
          <div class="lcard__fmts">
            {b.formats.map(f => <span class="lcard__fmt">{f}</span>)}
          </div>
          <a href={b.maps} target="_blank" rel="noopener" class="lcard__map">View on Maps ↗</a>
        </div>
      </div>
    ))}
  </div>

  <div class="lfoot reveal">
    <p class="eyebrow">Showing {branches.length} of 18 branches</p>
    <a href="/admin" class="lfoot__link">Manage all locations via CMS ↗</a>
  </div>

  <footer class="foot">
    <div class="foot__top">
      <div>
        <p class="foot__brand">Guss Damn Good</p>
        <p class="foot__sub">18 Branches · Bangkok, Thailand</p>
      </div>
      <nav class="foot__nav">
        <a href="/flavors">Flavors</a>
        <a href="/story">Story</a>
        <a href="/collabs">Collabs</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  /* HEADER */
  .lh { display:flex; align-items:flex-end; justify-content:space-between; padding:8rem var(--gutter) 3rem; border-bottom:1px solid var(--g2); gap:2rem; flex-wrap:wrap; }
  .lh__title { font-size:clamp(3rem,8vw,7rem); font-weight:500; color:var(--white); letter-spacing:-0.02em; line-height:0.95; margin-top:0.75rem; margin-bottom:0.75rem; }
  .lh__sub { font-family:var(--f); font-size:0.8rem; color:var(--g5); font-weight:300; }
  .lh__meta { display:flex; gap:2.5rem; align-items:flex-end; flex-shrink:0; }
  .lh__stat { display:flex; flex-direction:column; gap:0.3rem; }
  .lh__n { font-family:var(--f); font-weight:400; font-size:clamp(2rem,4vw,3.2rem); color:var(--white); line-height:1; letter-spacing:-0.02em; }

  /* DELIVERY BAR */
  .dbar { display:flex; align-items:center; justify-content:space-between; padding:0.85rem var(--gutter); border-bottom:1px solid var(--g2); background:var(--g1); flex-wrap:wrap; gap:0.75rem; }
  .dbar__apps { font-family:var(--f); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--white); font-weight:400; }

  /* 3-COL GRID */
  .lgrid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }

  .lcard { background:var(--g1); display:flex; flex-direction:column; cursor:pointer; }

  /* THUMBNAIL */
  .lcard__thumb { position:relative; aspect-ratio:16/10; overflow:hidden; background:#080808; }
  .lcard__thumb img { width:100%; height:100%; object-fit:cover; display:block; filter:grayscale(0.15); transition:transform 0.55s ease, filter 0.4s ease; }
  .lcard:hover .lcard__thumb img { transform:scale(1.05); filter:grayscale(0); }
  .lcard__dlv { position:absolute; top:0.6rem; right:0.6rem; font-family:var(--f); font-size:0.46rem; letter-spacing:0.2em; text-transform:uppercase; background:var(--white); color:var(--black); padding:0.18rem 0.52rem; font-weight:500; }

  /* BODY */
  .lcard__body { padding:1.1rem 1.15rem 1.4rem; display:flex; flex-direction:column; gap:0.65rem; flex:1; }
  .lcard__name { font-family:var(--f); font-weight:500; font-size:clamp(0.9rem,1.5vw,1.2rem); color:var(--white); letter-spacing:-0.01em; line-height:1.2; }
  .lcard__addr { font-family:var(--f); font-size:0.75rem; color:var(--g5); line-height:1.5; font-weight:300; }
  .lcard__rows { display:flex; flex-direction:column; gap:0.3rem; padding-top:0.5rem; border-top:1px solid var(--g2); }
  .lcard__row  { display:flex; align-items:baseline; gap:0.65rem; }
  .lcard__v    { font-family:var(--f); font-size:0.75rem; color:var(--white); font-weight:300; }
  .lcard__fmts { display:flex; gap:0.3rem; flex-wrap:wrap; }
  .lcard__fmt  { font-family:var(--f); font-size:0.46rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--g4); border:1px solid var(--g2); padding:0.14rem 0.45rem; font-weight:300; }
  .lcard__map  { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--white); text-decoration:none; font-weight:400; margin-top:auto; padding-top:0.75rem; border-top:1px solid var(--g2); transition:opacity 0.22s; display:block; }
  .lcard__map:hover { opacity:0.45; }

  /* FOOTER STRIP */
  .lfoot { display:flex; align-items:center; justify-content:space-between; padding:1.4rem var(--gutter); flex-wrap:wrap; gap:1rem; }
  .lfoot__link { font-family:var(--f); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--white); text-decoration:none; font-weight:300; transition:opacity 0.22s; }
  .lfoot__link:hover { opacity:0.5; }

  /* FOOT */
  .foot { padding:2.5rem var(--gutter); display:flex; flex-direction:column; gap:1.25rem; border-top:1px solid var(--g2); }
  .foot__top { display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.5rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:clamp(1.1rem,2vw,1.7rem); color:var(--white); letter-spacing:0.06em; text-transform:uppercase; }
  .foot__sub   { font-family:var(--f); font-size:0.48rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--g4); margin-top:0.25rem; font-weight:300; }
  .foot__nav   { display:flex; gap:2rem; flex-wrap:wrap; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; font-weight:300; transition:color 0.22s; }
  .foot__nav a:hover { color:var(--white); }
  .foot__copy  { font-family:var(--f); font-size:0.46rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:900px){ .lgrid { grid-template-columns:repeat(2,1fr); } .lh { flex-direction:column; align-items:flex-start; } }
  @media(max-width:560px){ .lgrid { grid-template-columns:1fr; } }
</style>
