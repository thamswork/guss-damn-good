---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import FlavorCard from '../components/FlavorCard.astro';
import { getCollection } from 'astro:content';

const allFlavors = await getCollection('flavors').catch(() => []);
const pinned   = allFlavors.filter(f => f.data.pinned).slice(0, 2);
const rest     = allFlavors.filter(f => !f.data.pinned);
const ordered  = [...pinned, ...rest];
const total    = allFlavors.length;
---

<BaseLayout title="Flavors — Guss Damn Good">
  <Nav/>

  <!-- COMPACT HEADER -->
  <header class="fh reveal">
    <div class="fh__text">
      <p class="eyebrow" style="margin-bottom:0.75rem;">Bangkok · Since 2014</p>
      <h1 class="fh__title">{total > 10 ? `${total}+` : '200+'} Flavors.</h1>
      <p class="fh__sub">Every flavor is a story. Scroll, discover, feel something.</p>
    </div>
  </header>

  <!-- FILTER TABS -->
  <div class="ftabs">
    <button class="ft ft-active" data-filter="all">All</button>
    <button class="ft" data-filter="current">Current</button>
    <button class="ft" data-filter="emerging">Emerging</button>
    <button class="ft" data-filter="archive">Archive</button>
    <button class="ft" data-filter="collab">Collabs</button>
    <button class="ft" data-filter="sorbet">Sorbet</button>
  </div>

  <!-- 3-COL GRID — matches homepage -->
  <div class="fgrid" id="fgrid">
    {ordered.length > 0
      ? ordered.map((f, i) => (
          <div
            class={`fgrid__item reveal reveal-delay-${(i % 3) + 1}`}
            data-status={f.data.status || 'current'}
            data-cat={f.data.category || 'classic'}
          >
            <FlavorCard
              flavorName={f.data.flavor_name}
              moodNumber={f.data.mood_number}
              productImage={f.data.product_image}
              productVideo={f.data.product_video}
              category={f.data.category}
              inStock={f.data.in_stock}
            description={f.data.description}
              description={f.data.description}
              pinned={f.data.pinned}
            />
          </div>
        ))
      : <p style="color:var(--g5);padding:3rem var(--gutter);font-family:var(--f);font-size:0.8rem;font-weight:300;">No flavors yet — add some in the CMS.</p>
    }
  </div>

  <div class="fcta reveal">
    <p class="eyebrow">200+ flavors and counting · Updated via CMS</p>
    <a href="/admin" style="font-family:var(--f);font-size:0.52rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--white);text-decoration:none;font-weight:300;border-bottom:1px solid var(--g3);padding-bottom:2px;">Manage flavors ↗</a>
  </div>

  <footer class="foot">
    <div class="foot__top">
      <p class="foot__brand">Guss Damn Good</p>
      <nav class="foot__nav">
        <a href="/">Home</a>
        <a href="/story">Story</a>
        <a href="/locations">Find Us</a>
        <a href="/collabs">Collabs</a>
      </nav>
    </div>
    <p class="foot__copy">© 2014–2025 Guss Damn Good</p>
  </footer>
</BaseLayout>

<style>
  /* HEADER — compact, not screaming */
  .fh { padding:calc(var(--nav-h) + 3rem) var(--gutter) 3rem; border-bottom:1px solid var(--g2); }
  .fh__title { font-family:var(--f); font-weight:500; font-size:clamp(2.5rem,6vw,5rem); color:#FFFFFF; line-height:1; letter-spacing:-0.02em; margin-top:0.5rem; margin-bottom:0.75rem; }
  .fh__sub { font-family:var(--f); font-size:0.82rem; color:var(--g5); font-weight:300; }

  /* FILTER TABS */
  .ftabs { display:flex; gap:0; border-bottom:1px solid var(--g2); overflow-x:auto; scrollbar-width:none; }
  .ftabs::-webkit-scrollbar { display:none; }
  .ft { background:none; border:none; border-right:1px solid var(--g2); padding:0.8rem 1.4rem; font-family:var(--f); font-size:0.52rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--g4); cursor:pointer; white-space:nowrap; transition:all 0.22s ease; font-weight:400; }
  .ft:hover { color:#FFFFFF; background:var(--g1); }
  .ft-active { color:#FFFFFF; background:var(--g1); }

  /* 3-COL GRID — same as homepage */
  .fgrid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); border-bottom:1px solid var(--g2); }
  .fgrid__item.hidden { display:none; }
  .fgrid .fc__img { aspect-ratio:4/5; }

  .fcta { display:flex; align-items:center; justify-content:space-between; padding:1.25rem var(--gutter); border-bottom:1px solid var(--g2); flex-wrap:wrap; gap:1rem; }

  /* FOOTER */
  .foot { padding:2rem var(--gutter); display:flex; flex-direction:column; gap:1rem; }
  .foot__top { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; padding-bottom:1.25rem; border-bottom:1px solid var(--g2); }
  .foot__brand { font-family:var(--f); font-weight:600; font-size:1.1rem; color:#FFFFFF; letter-spacing:0.06em; text-transform:uppercase; }
  .foot__nav { display:flex; gap:2rem; flex-wrap:wrap; }
  .foot__nav a { font-family:var(--f); font-size:0.5rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--g4); text-decoration:none; transition:color 0.22s; }
  .foot__nav a:hover { color:#FFFFFF; }
  .foot__copy { font-family:var(--f); font-size:0.46rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--g2); }

  @media(max-width:768px){
    .fgrid { grid-template-columns:repeat(2,1fr); }
    .fh__title { font-size:clamp(2rem,8vw,3.5rem); }
  }
  @media(max-width:480px){ .fgrid { grid-template-columns:1fr 1fr; } }
</style>

<script>
  var tabs  = document.querySelectorAll('.ft');
  var items = document.querySelectorAll('.fgrid__item');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t){ t.classList.remove('ft-active'); });
      tab.classList.add('ft-active');
      var filter = tab.dataset.filter;
      items.forEach(function(item) {
        if (filter === 'all') {
          item.classList.remove('hidden');
        } else {
          var status = item.dataset.status;
          var cat    = item.dataset.cat;
          item.classList.toggle('hidden', status !== filter && cat !== filter);
        }
      });
    });
  });
</script>
