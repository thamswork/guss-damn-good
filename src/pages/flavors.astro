---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const flavors = [
  { id:0, flavorName:"Breakfast Fresh Milk", moodNumber:"Mood #01", productImage:"https://images.unsplash.com/photo-1563805042-7684c019e1cb?w=800&q=80", description:"Farm-fresh milk slow-churned into Boston-style silk. The flavor that started it all in 2014. Gentle, clean, deeply nostalgic.", category:"classic", status:"current", inStock:true, pinned:true, locations:["Siam Paragon","Central World","EmQuartier","Delivery Available"] },
  { id:1, flavorName:"Very Addicted Crispy Corn", moodNumber:"Mood #07", productImage:"https://images.unsplash.com/photo-1488900128323-21503983a07e?w=800&q=80", description:"Sweet corn base with caramelised crispy corn crunch folded throughout. Addictive from the first bite.", category:"classic", status:"current", inStock:true, pinned:true, locations:["All 18 Branches","Delivery Available"] },
  { id:2, flavorName:"S'more Crunch", moodNumber:"Mood #14", productImage:"https://images.unsplash.com/photo-1534706936160-d5ee67737249?w=800&q=80", description:"Toasted marshmallow, dark chocolate fudge, crushed graham cracker. Campfire in a cup.", category:"classic", status:"current", inStock:true, pinned:false, locations:["Siam Paragon","Central Chidlom","EmQuartier"] },
  { id:3, flavorName:"Papaya x RIMOWA", moodNumber:"Collab", productImage:"https://images.unsplash.com/photo-1560008581-09826d1de69e?w=800&q=80", description:"Created exclusively for RIMOWA Bangkok flagship launch. Papaya sorbet meets mint cookie chip. 400 scoops in 2 hours.", category:"collab", status:"archive", inStock:false, pinned:false, locations:["Archive — No longer available"] },
  { id:4, flavorName:"Almond Crunch", moodNumber:"Mood #22", productImage:"https://images.unsplash.com/photo-1516559228935-0b788caa0b4d?w=800&q=80", description:"Roasted almond butter with dark chocolate brittle shards. Rich, nutty, satisfying.", category:"classic", status:"current", inStock:true, pinned:false, locations:["All 18 Branches","Delivery Available"] },
  { id:5, flavorName:"Greek Yogurt x Valentino", moodNumber:"Collab", productImage:"https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=800&q=80", description:"For Valentino SS23 Bangkok. Tangy Greek yogurt with lemon zest. Featured in Vogue Thailand.", category:"collab", status:"archive", inStock:false, pinned:false, locations:["Archive — No longer available"] },
  { id:6, flavorName:"Black Sesame", moodNumber:"Mood #33", productImage:"https://images.unsplash.com/photo-1497034825429-c343d7c6a68f?w=800&q=80", description:"Deep-roasted black sesame paste folded into French cream. Earthy, dark, quietly complex.", category:"classic", status:"current", inStock:true, pinned:false, locations:["Siam Paragon","EmQuartier","Delivery Available"] },
  { id:7, flavorName:"Mango Sticky Rice", moodNumber:"Mood #42", productImage:"https://images.unsplash.com/photo-1505394033641-40b6ad5ef923?w=800&q=80", description:"Nam Dok Mai mango with salted coconut cream ripple. Thailand's favourite dessert in Boston texture.", category:"seasonal", status:"emerging", inStock:true, pinned:false, locations:["Siam Paragon","Central World","Limited Run"] },
  { id:8, flavorName:"Pandan Coconut", moodNumber:"Mood #55", productImage:"https://images.unsplash.com/photo-1488477181946-6428a0291777?w=800&q=80", description:"Fragrant pandan with thick coconut milk from Southern Thailand.", category:"classic", status:"emerging", inStock:true, pinned:false, locations:["EmQuartier","Limited Run"] },
  { id:9, flavorName:"Salted Caramel Pretzel", moodNumber:"Mood #18", productImage:"https://images.unsplash.com/photo-1557142046-c704a3adf364?w=800&q=80", description:"Burnt caramel, Maldon sea salt, crushed pretzel shards. Perfect sweet-salt tension.", category:"classic", status:"current", inStock:true, pinned:false, locations:["All 18 Branches"] },
  { id:10, flavorName:"Taro Milk Tea", moodNumber:"Mood #61", productImage:"https://images.unsplash.com/photo-1558618047-f4e90e8a741b?w=800&q=80", description:"Thai taro meets Hong Kong milk tea. Creamy, earthy, boldly purple.", category:"classic", status:"emerging", inStock:true, pinned:false, locations:["Central World","Siam Paragon","Limited Run"] },
  { id:11, flavorName:"Strawberry Basil Sorbet", moodNumber:"Mood #29", productImage:"https://images.unsplash.com/photo-1488900128323-21503983a07e?w=800&q=80", description:"Fresh strawberry sorbet with garden basil. Bright, herbal, refreshing.", category:"sorbet", status:"archive", inStock:false, pinned:false, locations:["Archive — Check back next summer"] },
];

const filters = [
  {key:"all",label:"All"},
  {key:"current",label:"Current"},
  {key:"emerging",label:"Emerging"},
  {key:"archive",label:"Archive"},
  {key:"collab",label:"Collabs"},
  {key:"sorbet",label:"Sorbet"},
];
---
<BaseLayout title="Flavors — Guss Damn Good">
  <Nav/>

  <header class="fh">
    <div class="fh__left">
      <h1 class="fh__title">200+ Flavors.</h1>
      <p class="fh__sub">Every flavor is a story. Scroll, discover, feel something.</p>
    </div>
    <span class="fh__ghost">200</span>
  </header>

  <div class="fbar">
    <div class="fbar__filters">
      {filters.map(f=><button class={`fb${f.key==='all'?' fb-on':''}`} data-f={f.key}>{f.label}</button>)}
    </div>
    <span class="fbar__count" id="fcount">{flavors.length} flavors</span>
  </div>

  <div class="fg" id="fg">
    {flavors.map(f=>(
      <div class={`fgi${f.pinned?' fgi-pin':''}${!f.inStock?' fgi-out':''}`} data-status={f.status} data-cat={f.category} data-id={f.id} role="button" tabindex="0">
        <div class="fgi__img">
          <img src={f.productImage} alt={f.flavorName} loading={f.id<4?'eager':'lazy'}/>
          {f.pinned && <span class="fgi__badge fgi__badge--pin">Pinned</span>}
          {!f.inStock && <span class="fgi__badge fgi__badge--out">Archive</span>}
          {f.status==='emerging'&&f.inStock && <span class="fgi__badge fgi__badge--new">New</span>}
        </div>
        <div class="fgi__body">
          <div class="fgi__row">
            <h2 class="fgi__name">{f.flavorName}</h2>
            <span class="fgi__cat">{f.category}</span>
          </div>
          <span class="fgi__mood">{f.moodNumber}</span>
        </div>
      </div>
    ))}
  </div>

  <!-- POPUP -->
  <div id="popup" style="position:fixed;inset:0;z-index:8000;display:flex;align-items:center;justify-content:center;padding:1.5rem;opacity:0;visibility:hidden;transition:opacity 0.3s,visibility 0.3s;">
    <div id="popup-bg" style="position:absolute;inset:0;background:rgba(0,0,0,0.88);backdrop-filter:blur(10px);"></div>
    <div style="position:relative;z-index:1;background:var(--g1);width:100%;max-width:820px;max-height:88vh;overflow-y:auto;display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--g2);">
      <div style="position:relative;overflow:hidden;">
        <img id="pop-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:block;min-height:360px;"/>
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.7) 0%,transparent 50%);"></div>
        <div style="position:absolute;bottom:1.25rem;left:1.25rem;">
          <span id="pop-mood" style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;"></span>
          <span id="pop-badge" style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.2rem 0.65rem;"></span>
        </div>
      </div>
      <div style="padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.5rem;overflow-y:auto;">
        <button id="pop-close" style="align-self:flex-end;background:none;border:1px solid var(--g3);color:var(--g4);width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.8rem;transition:all 0.2s;">✕</button>
        <h2 id="pop-name" style="font-family:var(--f-head);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--white);letter-spacing:-0.03em;line-height:1;margin-top:-0.5rem;"></h2>
        <p id="pop-desc" style="font-family:var(--f-body);font-size:0.9rem;color:var(--g5);line-height:1.8;font-weight:300;"></p>
        <div style="height:1px;background:var(--g2);"></div>
        <div>
          <p style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--g4);margin-bottom:0.75rem;">Where to get it</p>
          <ul id="pop-locs" style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;"></ul>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .fh { display:flex; align-items:flex-end; justify-content:space-between; padding:8rem var(--gutter) 3rem; border-bottom:1px solid var(--g2); gap:2rem; overflow:hidden; }
  .fh__title { font-family:var(--f-head); font-weight:800; font-size:clamp(4rem,12vw,10rem); color:var(--white); }
  .fh__sub { font-family:var(--f-body); font-size:0.9rem; color:var(--g5); margin-top:1rem; font-weight:300; }
  .fh__ghost { font-family:var(--f-head); font-weight:800; font-size:clamp(6rem,20vw,16rem); color:var(--g1); line-height:1; flex-shrink:0; }

  .fbar { display:flex; align-items:center; justify-content:space-between; padding:0.85rem var(--gutter); border-bottom:1px solid var(--g2); position:sticky; top:var(--nav-h); background:rgba(0,0,0,0.97); backdrop-filter:blur(16px); z-index:50; gap:1rem; flex-wrap:wrap; }
  .fbar__filters { display:flex; gap:0.4rem; flex-wrap:wrap; }
  .fb { background:none; border:1px solid var(--g2); color:var(--g4); padding:0.35rem 0.9rem; font-family:var(--f-ui); font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:all 0.2s; }
  .fb:hover { border-color:var(--white); color:var(--white); }
  .fb-on { background:var(--white); border-color:var(--white); color:var(--black); }
  .fbar__count { font-family:var(--f-ui); font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--g3); white-space:nowrap; }

  .fg { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); background:var(--g2); }
  .fgi { background:var(--g1); cursor:pointer; transition:background 0.2s; outline:none; }
  .fgi:hover { background:#0F0F0F; }
  .fgi-out { filter:grayscale(0.7); opacity:0.5; }
  .fgi-pin { outline:1px solid rgba(255,255,255,0.1); }
  .fgi__img { position:relative; aspect-ratio:3/4; overflow:hidden; background:#080808; }
  .fgi__img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.6s ease; }
  .fgi:hover .fgi__img img { transform:scale(1.05); }
  .fgi__badge { position:absolute; font-family:var(--f-ui); font-size:0.52rem; letter-spacing:0.18em; text-transform:uppercase; padding:0.22rem 0.6rem; }
  .fgi__badge--pin { top:0.75rem; left:0.75rem; background:var(--white); color:var(--black); }
  .fgi__badge--out { top:0.75rem; right:0.75rem; background:rgba(0,0,0,0.85); color:var(--g4); border:1px solid var(--g3); }
  .fgi__badge--new { top:0.75rem; left:0.75rem; background:var(--white); color:var(--black); }
  .fgi__body { padding:0.9rem 1rem 1.2rem; display:flex; flex-direction:column; gap:0.25rem; }
  .fgi__row { display:flex; align-items:flex-start; justify-content:space-between; gap:0.5rem; }
  .fgi__name { font-family:var(--f-head); font-weight:700; font-size:clamp(0.95rem,1.5vw,1.2rem); color:var(--white); letter-spacing:-0.01em; line-height:1.1; flex:1; }
  .fgi__cat { font-family:var(--f-ui); font-size:0.52rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--g3); white-space:nowrap; padding-top:0.2rem; }
  .fgi__mood { font-family:var(--f-ui); font-size:0.52rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--g3); }

  #pop-close:hover { background:var(--white) !important; color:var(--black) !important; }
  #pop-locs li { font-family:var(--f-body); font-size:0.85rem; color:var(--white); padding-left:1rem; position:relative; }
  #pop-locs li::before { content:'—'; position:absolute; left:0; color:var(--g3); }

  @media(max-width:900px){ .fg { grid-template-columns:repeat(2,1fr); } .fh { flex-direction:column; align-items:flex-start; } }
  @media(max-width:500px){ .fg { grid-template-columns:1fr; } }
</style>

<script>
  var flavors = [
    {id:0,flavorName:"Breakfast Fresh Milk",moodNumber:"Mood #01",productImage:"https://images.unsplash.com/photo-1563805042-7684c019e1cb?w=800&q=80",description:"Farm-fresh milk slow-churned into Boston-style silk. The flavor that started it all in 2014. Gentle, clean, deeply nostalgic.",status:"current",inStock:true,locations:["Siam Paragon","Central World","EmQuartier","Delivery Available"]},
    {id:1,flavorName:"Very Addicted Crispy Corn",moodNumber:"Mood #07",productImage:"https://images.unsplash.com/photo-1488900128323-21503983a07e?w=800&q=80",description:"Sweet corn base with caramelised crispy corn crunch folded throughout. Addictive from the first bite.",status:"current",inStock:true,locations:["All 18 Branches","Delivery Available"]},
    {id:2,flavorName:"S'more Crunch",moodNumber:"Mood #14",productImage:"https://images.unsplash.com/photo-1534706936160-d5ee67737249?w=800&q=80",description:"Toasted marshmallow, dark chocolate fudge, crushed graham cracker. Campfire in a cup.",status:"current",inStock:true,locations:["Siam Paragon","Central Chidlom","EmQuartier"]},
    {id:3,flavorName:"Papaya x RIMOWA",moodNumber:"Collab",productImage:"https://images.unsplash.com/photo-1560008581-09826d1de69e?w=800&q=80",description:"Created exclusively for RIMOWA Bangkok flagship launch. Papaya sorbet meets mint cookie chip. 400 scoops in 2 hours.",status:"archive",inStock:false,locations:["Archive — No longer available"]},
    {id:4,flavorName:"Almond Crunch",moodNumber:"Mood #22",productImage:"https://images.unsplash.com/photo-1516559228935-0b788caa0b4d?w=800&q=80",description:"Roasted almond butter with dark chocolate brittle shards. Rich, nutty, satisfying.",status:"current",inStock:true,locations:["All 18 Branches","Delivery Available"]},
    {id:5,flavorName:"Greek Yogurt x Valentino",moodNumber:"Collab",productImage:"https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=800&q=80",description:"For Valentino SS23 Bangkok. Tangy Greek yogurt with lemon zest. Featured in Vogue Thailand.",status:"archive",inStock:false,locations:["Archive — No longer available"]},
    {id:6,flavorName:"Black Sesame",moodNumber:"Mood #33",productImage:"https://images.unsplash.com/photo-1497034825429-c343d7c6a68f?w=800&q=80",description:"Deep-roasted black sesame paste folded into French cream. Earthy, dark, quietly complex.",status:"current",inStock:true,locations:["Siam Paragon","EmQuartier","Delivery Available"]},
    {id:7,flavorName:"Mango Sticky Rice",moodNumber:"Mood #42",productImage:"https://images.unsplash.com/photo-1505394033641-40b6ad5ef923?w=800&q=80",description:"Nam Dok Mai mango with salted coconut cream ripple. Thailand's favourite dessert in Boston texture.",status:"emerging",inStock:true,locations:["Siam Paragon","Central World","Limited Run"]},
    {id:8,flavorName:"Pandan Coconut",moodNumber:"Mood #55",productImage:"https://images.unsplash.com/photo-1488477181946-6428a0291777?w=800&q=80",description:"Fragrant pandan with thick coconut milk from Southern Thailand.",status:"emerging",inStock:true,locations:["EmQuartier","Limited Run"]},
    {id:9,flavorName:"Salted Caramel Pretzel",moodNumber:"Mood #18",productImage:"https://images.unsplash.com/photo-1557142046-c704a3adf364?w=800&q=80",description:"Burnt caramel, Maldon sea salt, crushed pretzel shards. Perfect sweet-salt tension.",status:"current",inStock:true,locations:["All 18 Branches"]},
    {id:10,flavorName:"Taro Milk Tea",moodNumber:"Mood #61",productImage:"https://images.unsplash.com/photo-1558618047-f4e90e8a741b?w=800&q=80",description:"Thai taro meets Hong Kong milk tea. Creamy, earthy, boldly purple.",status:"emerging",inStock:true,locations:["Central World","Siam Paragon","Limited Run"]},
    {id:11,flavorName:"Strawberry Basil Sorbet",moodNumber:"Mood #29",productImage:"https://images.unsplash.com/photo-1488900128323-21503983a07e?w=800&q=80",description:"Fresh strawberry sorbet with garden basil. Bright, herbal, refreshing.",status:"archive",inStock:false,locations:["Archive — Check back next summer"]},
  ];

  var popup = document.getElementById('popup');
  var popBg = document.getElementById('popup-bg');
  var popClose = document.getElementById('pop-close');

  function openPopup(id){
    var f = flavors.find(function(x){return x.id===id;});
    if(!f) return;
    document.getElementById('pop-img').src = f.productImage;
    document.getElementById('pop-img').alt = f.flavorName;
    document.getElementById('pop-name').textContent = f.flavorName;
    document.getElementById('pop-mood').textContent = f.moodNumber;
    document.getElementById('pop-desc').textContent = f.description;
    var badge = document.getElementById('pop-badge');
    badge.textContent = f.inStock ? f.status : 'Archive';
    badge.style.background = f.inStock ? 'rgba(255,255,255,0.15)' : 'transparent';
    badge.style.color = f.inStock ? '#fff' : '#666';
    badge.style.border = f.inStock ? 'none' : '1px solid #333';
    document.getElementById('pop-locs').innerHTML = f.locations.map(function(l){return '<li>'+l+'</li>';}).join('');
    popup.style.opacity='1'; popup.style.visibility='visible';
    document.body.style.overflow='hidden';
  }

  function closePopup(){
    popup.style.opacity='0'; popup.style.visibility='hidden';
    document.body.style.overflow='';
  }

  document.querySelectorAll('.fgi').forEach(function(el){
    el.addEventListener('click', function(){ openPopup(parseInt(el.dataset.id)); });
    el.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' ') openPopup(parseInt(el.dataset.id)); });
  });
  popClose && popClose.addEventListener('click', closePopup);
  popBg && popBg.addEventListener('click', closePopup);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closePopup(); });

  var btns = document.querySelectorAll('.fb');
  var items = document.querySelectorAll('.fgi');
  var count = document.getElementById('fcount');
  btns.forEach(function(btn){
    btn.addEventListener('click', function(){
      btns.forEach(function(b){b.classList.remove('fb-on');});
      btn.classList.add('fb-on');
      var f = btn.dataset.f;
      var n=0;
      items.forEach(function(item){
        var show = f==='all'||item.dataset.status===f||item.dataset.cat===f;
        item.style.display=show?'':'none';
        if(show) n++;
      });
      if(count) count.textContent=n+' flavors';
    });
  });
</script>
