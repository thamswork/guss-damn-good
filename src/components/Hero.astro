---
const {
  videoUrl = "",
  slides = [],
  headline1 = "GUSS IS A",
  headline2 = "DAMN GOOD",
  headline3 = "ICE CREAM",
} = Astro.props;
const hasVideo = videoUrl?.length > 0;
const hasSlides = slides?.length > 0;
---

<section class="hero">
  <div class="hero__bg">
    {hasVideo ? (
      <video class="hero__video" src={videoUrl} autoplay muted loop playsinline />
    ) : hasSlides ? (
      <div class="hero__slides" id="hero-slides">
        {slides.map((s, i) => (
          <div class={`hero__slide ${i===0 ? 'active' : ''}`} style={`background-image:url('${s}')`} />
        ))}
      </div>
    ) : (
      <div class="hero__fallback" />
    )}
    <div class="hero__dim" />
  </div>

  <div class="hero__type">
    <p class="hero__line hero__line--1">{headline1}</p>
    <p class="hero__line hero__line--2"><em>{headline2}</em></p>
    <p class="hero__line hero__line--3">{headline3}</p>
  </div>

  <div class="hero__bar">
    <span class="hero__bar-item">Feeling-Crafted</span>
    <span class="hero__bar-sep">·</span>
    <span class="hero__bar-item">Boston 2014</span>
    <span class="hero__bar-sep">·</span>
    <span class="hero__bar-item">Bangkok Now</span>
    <a href="/flavors" class="hero__bar-cta">See All Flavors →</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__video {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .hero__fallback {
    width: 100%; height: 100%;
    background: #0A0A0A;
  }

  .hero__slides {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero__slide.active { opacity: 1; }

  .hero__dim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,10,1) 0%,
      rgba(10,10,10,0.45) 40%,
      rgba(10,10,10,0.1) 100%
    );
  }

  .hero__type {
    position: relative;
    z-index: 10;
    padding: 0 var(--gutter) 0.5rem;
    line-height: 0.88;
  }

  .hero__line {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 17vw, 17rem);
    letter-spacing: -0.01em;
    color: #F0EDE8;
    display: block;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
  }

  .hero__line--1 { animation-delay: 3s; }
  .hero__line--2 { animation-delay: 3.15s; }
  .hero__line--3 { animation-delay: 3.3s; }

  .hero__line em {
    font-style: italic;
    font-family: 'DM Serif Display', serif;
    color: #F0EDE8;
    font-size: 0.82em;
  }

  .hero__bar {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem var(--gutter);
    border-top: 1px solid rgba(255,255,255,0.08);
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeIn 0.6s ease 3.5s forwards;
  }

  .hero__bar-item {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #555;
  }

  .hero__bar-sep {
    color: #333;
  }

  .hero__bar-cta {
    margin-left: auto;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F0EDE8;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .hero__bar-cta:hover { opacity: 0.5; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn { to { opacity: 1; } }
</style>

<script>
  const slides = document.querySelectorAll('.hero__slide');
  if (slides.length > 1) {
    let cur = 0;
    setInterval(() => {
      slides[cur].classList.remove('active');
      cur = (cur + 1) % slides.length;
      slides[cur].classList.add('active');
    }, 5000);
  }
</script>
