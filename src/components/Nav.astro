---
const { mode = "consumer" } = Astro.props;
---

<header id="main-nav" style="
  position:fixed;top:0;left:0;right:0;z-index:300;
  height:var(--nav-h);display:flex;align-items:center;
  justify-content:space-between;padding:0 var(--gutter);
  border-bottom:1px solid transparent;">

  <a href="/" style="text-decoration:none;display:flex;flex-direction:column;line-height:1;gap:3px;">
    <span style="font-family:var(--f);font-weight:600;font-size:0.9rem;color:var(--white);letter-spacing:0.1em;text-transform:uppercase;">Guss Damn Good</span>
    <span style="font-family:var(--f);font-size:0.48rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--g5);font-weight:300;">Feeling-Crafted Ice Cream</span>
  </a>

  <button id="nav-btn" aria-label="Open menu"
    style="background:none;border:none;cursor:pointer;display:flex;flex-direction:column;gap:5px;width:24px;padding:0;">
    <span class="nb" style="display:block;height:1px;background:var(--white);width:100%;transition:width 0.25s ease;"></span>
    <span class="nb" style="display:block;height:1px;background:var(--white);width:62%;transition:width 0.25s ease;"></span>
    <span class="nb" style="display:block;height:1px;background:var(--white);width:38%;transition:width 0.25s ease;"></span>
  </button>
</header>

<div id="nav-ov" style="
  position:fixed;inset:0;z-index:9000;
  display:grid;grid-template-columns:1fr 1fr;
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity 0.35s ease, visibility 0.35s ease;">

  <div id="nav-L" style="
    background:var(--g1);border-right:1px solid var(--g2);
    display:flex;flex-direction:column;padding-top:var(--nav-h);
    transform:translateX(-100%);
    transition:transform 0.42s cubic-bezier(0.77,0,0.175,1);">

    <div style="padding:1.75rem var(--gutter);border-bottom:1px solid var(--g2);display:flex;align-items:center;justify-content:space-between;">
      <span class="eyebrow">Menu</span>
      <button id="nav-cl" style="background:none;border:1px solid var(--g3);color:var(--g5);width:28px;height:28px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.65rem;font-family:var(--f);transition:all 0.2s;">✕</button>
    </div>

    <nav style="flex:1;display:flex;flex-direction:column;justify-content:center;">
      <a href="/flavors"   class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:0.95rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.22s ease;">
        <span style="font-family:var(--f);font-weight:500;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Flavors</span>
        <span class="ne" style="font-size:1.2rem;opacity:0;transform:scale(0.5) rotate(-10deg);transition:all 0.22s ease;pointer-events:none;">🍦</span>
      </a>
      <a href="/story"     class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:0.95rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.22s ease;">
        <span style="font-family:var(--f);font-weight:500;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Story</span>
        <span class="ne" style="font-size:1.2rem;opacity:0;transform:scale(0.5) rotate(-10deg);transition:all 0.22s ease;pointer-events:none;">✦</span>
      </a>
      <a href="/locations" class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:0.95rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.22s ease;">
        <span style="font-family:var(--f);font-weight:500;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Find Us</span>
        <span class="ne" style="font-size:1.2rem;opacity:0;transform:scale(0.5) rotate(-10deg);transition:all 0.22s ease;pointer-events:none;">📍</span>
      </a>
      <a href="/collabs"   class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:0.95rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.22s ease;">
        <span style="font-family:var(--f);font-weight:500;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Collabs</span>
        <span class="ne" style="font-size:1.2rem;opacity:0;transform:scale(0.5) rotate(-10deg);transition:all 0.22s ease;pointer-events:none;">🤝</span>
      </a>
    </nav>

    <div style="padding:1.5rem var(--gutter);border-top:1px solid var(--g2);display:flex;flex-direction:column;gap:0.3rem;">
      <span class="eyebrow">Bangkok · Since 2014</span>
      <span class="eyebrow">200+ Flavors · 18 Branches</span>
    </div>
  </div>

  <div id="nav-R" style="
    background:#070707;display:flex;flex-direction:column;
    padding:var(--nav-h) var(--gutter) 2.5rem;justify-content:flex-end;
    transform:translateX(100%);
    transition:transform 0.42s cubic-bezier(0.77,0,0.175,1) 0.04s;">
    <p style="font-family:var(--f-script);font-size:2.8rem;color:var(--white);opacity:0.08;line-height:1.1;margin-bottom:2rem;">Damn<br/>Good.</p>
    <div style="border-top:1px solid var(--g2);padding-top:1.75rem;display:flex;flex-direction:column;gap:1rem;">
      <p style="font-family:var(--f);font-size:0.82rem;color:var(--g5);line-height:1.8;font-weight:300;">We believe ice cream carries feeling and can be passed between people. Every Guss flavor is crafted with our Story-to-Flavor philosophy.</p>
      <a href="mailto:collab@gussdamngood.com" style="font-family:var(--f);font-size:0.55rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--white);text-decoration:none;font-weight:400;border-bottom:1px solid var(--g3);padding-bottom:2px;align-self:flex-start;transition:border-color 0.2s;">Work with us ↗</a>
    </div>
  </div>
</div>

<style>
  .nl:hover { padding-left: calc(var(--gutter) + 0.5rem) !important; }
  .nl:hover .ne { opacity:1 !important; transform:scale(1) rotate(0deg) !important; }
  #nav-btn:hover .nb { width:100% !important; }
  #nav-cl:hover { background:var(--white) !important; color:var(--black) !important; border-color:var(--white) !important; }
</style>

<script>
  var btn = document.getElementById('nav-btn');
  var ov  = document.getElementById('nav-ov');
  var L   = document.getElementById('nav-L');
  var R   = document.getElementById('nav-R');
  var cl  = document.getElementById('nav-cl');

  function openNav() {
    ov.style.opacity='1'; ov.style.visibility='visible'; ov.style.pointerEvents='all';
    L.style.transform='translateX(0)'; R.style.transform='translateX(0)';
    document.body.style.overflow='hidden';
  }
  function closeNav() {
    ov.style.opacity='0'; ov.style.visibility='hidden'; ov.style.pointerEvents='none';
    L.style.transform='translateX(-100%)'; R.style.transform='translateX(100%)';
    document.body.style.overflow='';
  }

  btn && btn.addEventListener('click', openNav);
  cl  && cl.addEventListener('click',  closeNav);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeNav(); });
</script>
