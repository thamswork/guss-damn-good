---
const { mode = "consumer" } = Astro.props;
---

<header id="main-nav" style="position:fixed;top:0;left:0;right:0;z-index:300;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;">
  <a href="/" style="text-decoration:none;display:flex;flex-direction:column;line-height:1;gap:3px;">
    <span style="font-family:var(--f-head);font-weight:600;font-size:0.95rem;color:var(--white);letter-spacing:0.08em;text-transform:uppercase;">Guss Damn Good</span>
    <span style="font-family:var(--f-ui);font-size:0.48rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--g5);font-weight:400;">Feeling-Crafted Ice Cream</span>
  </a>
  <button id="nav-btn" aria-label="Open menu" style="background:none;border:none;cursor:pointer;display:flex;flex-direction:column;gap:5px;width:26px;padding:0;">
    <span class="bar" style="display:block;height:1px;background:var(--white);width:100%;transition:width 0.25s ease;"></span>
    <span class="bar" style="display:block;height:1px;background:var(--white);width:65%;transition:width 0.25s ease;"></span>
    <span class="bar" style="display:block;height:1px;background:var(--white);width:40%;transition:width 0.25s ease;"></span>
  </button>
</header>

<div id="nav-overlay" style="position:fixed;inset:0;z-index:9000;display:grid;grid-template-columns:1fr 1fr;opacity:0;visibility:hidden;pointer-events:none;transition:opacity 0.4s ease,visibility 0.4s ease;">
  <div id="nav-left" style="background:var(--g1);border-right:1px solid var(--g2);display:flex;flex-direction:column;padding-top:var(--nav-h);transform:translateX(-100%);transition:transform 0.45s cubic-bezier(0.77,0,0.175,1);">
    <div style="padding:2rem var(--gutter);border-bottom:1px solid var(--g2);display:flex;align-items:center;justify-content:space-between;">
      <span class="eyebrow">Navigation</span>
      <button id="nav-close" style="background:none;border:1px solid var(--g3);color:var(--g4);width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.7rem;transition:all 0.2s;font-family:var(--f-ui);">✕</button>
    </div>
    <nav style="flex:1;display:flex;flex-direction:column;justify-content:center;">
      <a href="/flavors" class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:1rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:600;font-size:clamp(1.6rem,3.5vw,2.5rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Flavors</span>
        <span class="ne" style="font-size:1.4rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">🍦</span>
      </a>
      <a href="/story" class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:1rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:600;font-size:clamp(1.6rem,3.5vw,2.5rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Story</span>
        <span class="ne" style="font-size:1.4rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">✦</span>
      </a>
      <a href="/locations" class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:1rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:600;font-size:clamp(1.6rem,3.5vw,2.5rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Find Us</span>
        <span class="ne" style="font-size:1.4rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">📍</span>
      </a>
      <a href="/collabs" class="nl" style="display:flex;align-items:center;justify-content:space-between;padding:1rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:600;font-size:clamp(1.6rem,3.5vw,2.5rem);color:var(--white);letter-spacing:-0.01em;text-transform:uppercase;">Collabs</span>
        <span class="ne" style="font-size:1.4rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">🤝</span>
      </a>
    </nav>
    <div style="padding:1.5rem var(--gutter);border-top:1px solid var(--g2);">
      <span class="eyebrow" style="display:block;margin-bottom:0.3rem;">Bangkok · Since 2014</span>
      <span class="eyebrow">200+ Flavors · 18 Branches</span>
    </div>
  </div>

  <div id="nav-right" style="background:#080808;display:flex;flex-direction:column;padding:var(--nav-h) var(--gutter) 3rem;justify-content:flex-end;transform:translateX(100%);transition:transform 0.45s cubic-bezier(0.77,0,0.175,1) 0.05s;">
    <p style="font-family:var(--f-script);font-size:3rem;color:var(--white);opacity:0.1;line-height:1.1;margin-bottom:2rem;">Feeling<br/>Crafted</p>
    <div style="border-top:1px solid var(--g2);padding-top:2rem;display:flex;flex-direction:column;gap:1rem;">
      <p style="font-family:var(--f-body);font-size:0.8rem;color:var(--g5);line-height:1.8;font-weight:300;">We believe ice cream carries feeling and can be passed between people. Every Guss flavor is crafted with our Story-to-Flavor philosophy.</p>
      <a href="mailto:collab@gussdamngood.com" style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white);text-decoration:none;border-bottom:1px solid var(--g3);padding-bottom:2px;align-self:flex-start;font-weight:400;">Work with us ↗</a>
    </div>
  </div>
</div>

<style>
  .nl:hover { padding-left:calc(var(--gutter) + 0.6rem) !important; }
  .nl:hover .ne { opacity:1 !important; transform:scale(1) !important; }
  #nav-btn:hover .bar { width:100% !important; }
  #nav-close:hover { background:var(--white) !important; color:var(--black) !important; }
</style>

<script>
  var btn=document.getElementById('nav-btn'),ov=document.getElementById('nav-overlay'),nl=document.getElementById('nav-left'),nr=document.getElementById('nav-right'),cl=document.getElementById('nav-close');
  function openNav(){ov.style.opacity='1';ov.style.visibility='visible';ov.style.pointerEvents='all';nl.style.transform='translateX(0)';nr.style.transform='translateX(0)';document.body.style.overflow='hidden';}
  function closeNav(){ov.style.opacity='0';ov.style.visibility='hidden';ov.style.pointerEvents='none';nl.style.transform='translateX(-100%)';nr.style.transform='translateX(100%)';document.body.style.overflow='';}
  btn&&btn.addEventListener('click',openNav);
  cl&&cl.addEventListener('click',closeNav);
  document.addEventListener('keydown',function(e){if(e.key==='Escape')closeNav();});
</script>
