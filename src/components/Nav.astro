---
const { mode = "consumer" } = Astro.props;
---

<header id="main-nav" style="position:fixed;top:0;left:0;right:0;z-index:300;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 var(--gutter);border-bottom:1px solid transparent;">

  <a href="/" style="text-decoration:none;display:flex;flex-direction:column;line-height:1;gap:2px;">
    <span style="font-family:var(--f-head);font-weight:800;font-size:1.05rem;color:var(--white);letter-spacing:-0.02em;">Guss Damn Good</span>
    <span style="font-family:var(--f-ui);font-size:0.52rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--g5);">Feeling-Crafted Ice Cream</span>
  </a>

  <button id="nav-btn" aria-label="Open menu" style="background:none;border:none;cursor:pointer;display:flex;flex-direction:column;gap:5px;width:28px;padding:0;">
    <span class="bar" style="display:block;height:1px;background:var(--white);width:100%;transition:all 0.3s;"></span>
    <span class="bar" style="display:block;height:1px;background:var(--white);width:65%;transition:all 0.3s;"></span>
    <span class="bar" style="display:block;height:1px;background:var(--white);width:40%;transition:all 0.3s;"></span>
  </button>
</header>

<!-- DIAGONAL SPLIT OVERLAY — unique interaction, not fullscreen block -->
<div id="nav-overlay" style="
  position:fixed;inset:0;z-index:9000;
  display:grid;grid-template-columns:1fr 1fr;
  pointer-events:none;opacity:0;visibility:hidden;
  transition:opacity 0.4s ease, visibility 0.4s ease;
">
  <!-- LEFT PANEL — dark, navigation -->
  <div id="nav-left" style="
    background:var(--g1);
    border-right:1px solid var(--g2);
    display:flex;flex-direction:column;
    padding:var(--nav-h) 0 3rem 0;
    transform:translateX(-100%);
    transition:transform 0.45s cubic-bezier(0.77,0,0.175,1);
  ">
    <div style="padding:2rem var(--gutter);border-bottom:1px solid var(--g2);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:var(--f-ui);font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--g4);">Navigation</span>
      <button id="nav-close" style="background:none;border:1px solid var(--g3);color:var(--g4);width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.75rem;transition:all 0.2s;">✕</button>
    </div>

    <nav style="flex:1;display:flex;flex-direction:column;justify-content:center;">
      <a href="/flavors" class="nav-link" data-emoji="🍦" style="display:flex;align-items:center;justify-content:space-between;padding:1.2rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--white);letter-spacing:-0.02em;">Flavors</span>
        <span class="nav-emoji" style="font-size:1.6rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">🍦</span>
      </a>
      <a href="/story" class="nav-link" data-emoji="✦" style="display:flex;align-items:center;justify-content:space-between;padding:1.2rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--white);letter-spacing:-0.02em;">Story</span>
        <span class="nav-emoji" style="font-size:1.6rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">✦</span>
      </a>
      <a href="/locations" class="nav-link" data-emoji="📍" style="display:flex;align-items:center;justify-content:space-between;padding:1.2rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--white);letter-spacing:-0.02em;">Locations</span>
        <span class="nav-emoji" style="font-size:1.6rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">📍</span>
      </a>
      <a href="/collabs" class="nav-link" data-emoji="🤝" style="display:flex;align-items:center;justify-content:space-between;padding:1.2rem var(--gutter);border-bottom:1px solid var(--g2);text-decoration:none;transition:padding-left 0.2s;">
        <span style="font-family:var(--f-head);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:var(--white);letter-spacing:-0.02em;">Collabs</span>
        <span class="nav-emoji" style="font-size:1.6rem;opacity:0;transform:scale(0.5);transition:all 0.25s;pointer-events:none;">🤝</span>
      </a>
    </nav>

    <div style="padding:2rem var(--gutter) 0;display:flex;flex-direction:column;gap:0.4rem;">
      <span style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--g3);">Bangkok · Since 2014</span>
      <span style="font-family:var(--f-ui);font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--g3);">200+ Flavors · 18 Branches</span>
    </div>
  </div>

  <!-- RIGHT PANEL — slightly lighter, brand info -->
  <div id="nav-right" style="
    background:#0A0A0A;
    display:flex;flex-direction:column;
    padding:var(--nav-h) var(--gutter) 3rem;
    justify-content:flex-end;
    transform:translateX(100%);
    transition:transform 0.45s cubic-bezier(0.77,0,0.175,1) 0.05s;
  ">
    <div style="margin-top:auto;display:flex;flex-direction:column;gap:2rem;">
      <p style="font-family:var(--f-script);font-size:3.5rem;color:var(--white);opacity:0.15;line-height:1.1;">Feeling<br/>Crafted</p>
      <div style="border-top:1px solid var(--g2);padding-top:2rem;display:flex;flex-direction:column;gap:1rem;">
        <p style="font-family:var(--f-ui);font-size:0.8rem;color:var(--g5);line-height:1.7;font-weight:300;">We believe ice cream carries feeling and can be passed between people. Every Guss flavor is crafted with our Story-to-Flavor philosophy.</p>
        <a href="mailto:collab@gussdamngood.com" style="font-family:var(--f-ui);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--white);text-decoration:none;border-bottom:1px solid var(--g3);padding-bottom:2px;align-self:flex-start;transition:border-color 0.2s;">Work with us ↗</a>
      </div>
    </div>
  </div>
</div>

<style>
  .nav-link:hover { padding-left: calc(var(--gutter) + 0.75rem) !important; }
  .nav-link:hover .nav-emoji { opacity:1 !important; transform:scale(1) !important; }
  #nav-close:hover { background:var(--white) !important; color:var(--black) !important; border-color:var(--white) !important; }
  .bar { transition: width 0.25s ease !important; }
  #nav-btn:hover .bar { width: 100% !important; }
</style>

<script>
  var btn = document.getElementById('nav-btn');
  var overlay = document.getElementById('nav-overlay');
  var left = document.getElementById('nav-left');
  var right = document.getElementById('nav-right');
  var close = document.getElementById('nav-close');

  function openNav(){
    overlay.style.opacity = '1';
    overlay.style.visibility = 'visible';
    overlay.style.pointerEvents = 'all';
    left.style.transform = 'translateX(0)';
    right.style.transform = 'translateX(0)';
    document.body.style.overflow = 'hidden';
  }

  function closeNav(){
    overlay.style.opacity = '0';
    overlay.style.visibility = 'hidden';
    overlay.style.pointerEvents = 'none';
    left.style.transform = 'translateX(-100%)';
    right.style.transform = 'translateX(100%)';
    document.body.style.overflow = '';
  }

  btn && btn.addEventListener('click', openNav);
  close && close.addEventListener('click', closeNav);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeNav(); });
</script>
